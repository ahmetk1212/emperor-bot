        tokenizer._spm.load(str(model_path))
        tokenizer._is_trained = True
        
        return tokenizer


class CharLevelTokenizer(TokenizerWrapper):
    """
    Character-Level Tokenizer.
    
    En basit tokenizer:
    - Her karakter = 1 token
    - Vocab = tüm benzersiz karakterler
    
    Avantajları:
    - Çok küçük vocab
    - Hiç OOV problemi yok
    - Uzun sequence'ler
    
    Dezavantajları:
    - Çok uzun token dizileri
    - Anlamsal bilgi az
    
    Kullanım:
    - Deneysel
    - Test/benchmark için
    - Küçük modeller için
    """
    
    def __init__(
        self,
        vocab: Optional[List[str]] = None,
        pad_token: str = "<pad>",
        unk_token: str = "<unk>"
    ):
        self.pad_token = pad_token
        self.unk_token = unk_token
        
        if vocab:
            self.vocab = vocab
        else:
            self.vocab = [pad_token, unk_token]
        
        self._build_vocab()
    
    def _build_vocab(self):
        """Vocab oluştur."""
        self.char_to_id = {c: i for i, c in enumerate(self.vocab)}
        self.id_to_char = {i: c for i, c in enumerate(self.vocab)}
        
        self.unk_id = self.char_to_id.get(self.unk_token, 0)
        self.pad_id = self.char_to_id.get(self.pad_token, 0)
    
    @property
    def vocab_size_property(self) -> int:
        return len(self.vocab)
    
    @property
    def eos_token_id(self) -> int:
        return self.pad_id
    
    @property
    def pad_token_id(self) -> int:
        return self.pad_id
    
    def train(self, texts: List[str]):
        """Karakter vocab oluştur."""
        # Tüm benzersiz karakterleri topla
        chars = set()
        for text in texts:
            chars.update(text)
        
        # Özel token'ları ekle
        self.vocab = [self.pad_token, self.unk_token] + 
sorted(list(chars))
        self._build_vocab()
        
        print(f"Char-Level Tokenizer: {len(self.vocab)} karakter")
    
    def encode(
        self,
        text: str,
        max_length: Optional[int] = None,
        add_special_tokens: bool = False
    ) -> List[int]:
        """Metni karakterlerine ayır."""
        ids = []
        for char in text:
            char_id = self.char_to_id.get(char, self.unk_id)
            ids.append(char_id)
        
        if max_length and len(ids) > max_length:
            ids = ids[:max_length]
        
        return ids
    
    def decode(self, ids: List[int], skip_special_tokens: bool = 
True) -> str:
        """ID'leri karakterlere çevir."""
        chars = []
        for id_ in ids:
            if skip_special_tokens and id_ in [self.unk_id, 
self.pad_id]:
                continue
            chars.append(self.id_to_char.get(id_, self.unk_token))
        
        return "".join(chars)
    
    def batch_encode(
        self,
        texts: List[str],
        max_length: Optional[int] = None,
        padding: bool = True,
        truncation: bool = True
    ) -> Dict[str, torch.Tensor]:
        """Batch encoding."""
        input_ids = []
        attention_masks = []
        
        for text in texts:
            ids = self.encode(text, max_length=max_length)
            input_ids.append(ids)
        
        # Determine max length
        max_len = max_length or max(len(ids) for ids in input_ids)
        
        # Pad
        for ids in input_ids:
            if len(ids) < max_len:
                ids.extend([self.pad_id] * (max_len - len(ids)))
            
            attention_masks.append([1 if i < len(ids) else 0 for i 
in range(max_len)])
        
        return {
            "input_ids": torch.tensor(input_ids, dtype=torch.long),
            "attention_mask": torch.tensor(attention_masks, 
dtype=torch.long)
        }
    
    def batch_decode(
        self,
        batch_ids: List[List[int]],
        skip_special_tokens: bool = True
    ) -> List[str]:
        return [self.decode(ids) for ids in batch_ids]
    
    def save(self, save_dir: Union[str, Path]):
        """Vocab kaydet."""
        save_dir = Path(save_dir)
        save_dir.mkdir(parents=True, exist_ok=True)
        
        vocab_file = save_dir / "vocab.json"
        
        data = {
            "vocab": self.vocab,
            "pad_token": self.pad_token,
            "unk_token": self.unk_token
        }
        
        with open(vocab_file, "w") as f:
            json.dump(data, f)
    
    @classmethod
    def load(cls, load_dir: Union[str, Path]) -> 
"CharLevelTokenizer":
        """Vocab yükle."""
        load_dir = Path(load_dir)
        vocab_file = load_dir / "vocab.json"
        
        with open(vocab_file) as f:
            data = json.load(f)
        
        tokenizer = cls(
            vocab=data["vocab"],
            pad_token=data["pad_token"],
            unk_token=data["unk_token"]
        )
        
        return tokenizer
        

