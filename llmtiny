def _manual_attention(
    q: torch.Tensor,
    k: torch.Tensor,
    v: torch.Tensor,
    mask: Optional[torch.Tensor],
    dropout_p: float,
    softmax_scale: float,
    causal: bool
) -> Tuple[torch.Tensor, torch.Tensor]:
    """
    Manual attention implementation (no flash_attn).
    
    Bu reference implementation'tır.
    Production için flash_attn kullanılmalı.
    """
    # Scale
    q = q * softmax_scale
    
    # Compute attention scores
    # (batch, heads, seq, head_dim) @ (batch, heads, head_dim, seq)
    # → (batch, heads, seq, seq)
    attn = torch.matmul(q, k.transpose(-2, -1))
    
    # Causal mask
    if causal:
        seq_len = q.size(2)
        causal_mask = torch.triu(
            torch.ones(seq_len, seq_len, device=q.device, dtype=torch.bool),
            diagonal=1
        )
        attn = attn.masked_fill(causal_mask, float('-inf'))
    
    # Additional mask
    if mask is not None:
        attn = attn.masked_fill(mask == 0, float('-inf'))
    
    # Softmax
    attn_weights = F.softmax(attn, dim=-1)
    
    # Dropout
    if dropout_p > 0 and self.training:
        attn_weights = F.dropout(attn_weights, p=dropout_p)
    
    # Apply to values
    output = torch.matmul(attn_weights, v)
    
    return output, attn_weights


class FlashAttentionBlock(nn.Module):
    """
    Flash Attention Block with pre-norm.
    
    Mimari:
    ┌────────────────────────────────────────────────────┐
    │ Input: x (batch, seq, hidden)                     │
    │         ↓                                         │
    │ ┌────────────────────────────────────────────────┐│
    │ │ RMSNorm(x)                                     ││
    │ └────────────────────────────────────────────────┘│
    │         ↓                                         │
    │ ┌────────────────────────────────────────────────┐│
    │ │ Q, K, V Projections                           ││
    │ │ Q = W_q @ x_norm                               ││
    │ │ K = W_k @ x_norm                               ││
    │ │ V = W_v @ x_norm                               ││
    │ │ Shape: (batch, seq, hidden)                    ││
    │ └────────────────────────────────────────────────┘│
    │         ↓                                         │
    │ ┌────────────────────────────────────────────────┐│
    │ │ Reshape + RoPE (optional)                      ││
    │ │ → (batch, heads, seq, head_dim)               ││
    │ └────────────────────────────────────────────────┘│
    │         ↓                                         │
    │ ┌────────────────────────────────────────────────┐│
    │ │ Flash Attention                               ││
    │ │ O(n) memory, optimized compute                ││
    │ └────────────────────────────────────────────────┘│
    │         ↓                                         │
    │ ┌────────────────────────────────────────────────┐│
    │ │ Output Projection                              ││
    │ │ out = W_o @ attn_output + residual             ││
    │ └────────────────────────────────────────────────┘│
    │         ↓                                         │
    │ Output: (batch, seq, hidden)                     │
    └────────────────────────────────────────────────────┘
    
    Args:
        hidden_size: Model dimension
        num_heads: Number of attention heads
        head_dim: Dimension per head
        dropout: Dropout probability
        bias: Use bias in projections
    """
    
    def __init__(
        self,
        hidden_size: int,
        num_heads: int,
        head_dim: int = 64,
        dropout: float = 0.0,
        bias: bool = False
    ):
        super().__init__()
        
        self.hidden_size = hidden_size
        self.num_heads = num_heads
        self.head_dim = head_dim
        self.dropout = dropout
        
        # Pre-norm
        self.norm = nn.RMSNorm(hidden_size)
        
        # Q, K, V projections
        self.q_proj = nn.Linear(hidden_size, hidden_size, bias=bias)
        self.k_proj = nn.Linear(hidden_size, hidden_size, bias=bias)
        self.v_proj = nn.Linear(hidden_size, hidden_size, bias=bias)
        
        # Output projection
        self.out_proj = nn.Linear(hidden_size, hidden_size, bias=bias)
        
        # Dropout
        self.attn_dropout = nn.Dropout(dropout) if dropout > 0 else nn.Identity()
        
        # Scale
        self.scale = 1.0 / math.sqrt(head_dim)
    
    def forward(
        self,
        x: torch.Tensor,
        attention_mask: Optional[torch.Tensor] = None,
        is_causal: bool = True
    ) -> torch.Tensor:
        """
        Args:
            x: (batch, seq_len, hidden_size)
            attention_mask: Optional mask
            is_causal: Apply causal masking
            
        Returns:
            output: (batch, seq_len, hidden_size)
        """
        batch_size, seq_len, _ = x.shape
        
        # Pre-norm
        x_norm = self.norm(x)
        
        # Q, K, V projections
        q = self.q_proj(x_norm)
        k = self.k_proj(x_norm)
        v = self.v_proj(x_norm)
        
        # Reshape for multi-head attention
        # (batch, seq, hidden) → (batch, heads, seq, head_dim)
        q = q.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 
2)
        k = k.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 
2)
        v = v.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 
2)
        
        # Flash attention
        attn_output, _ = flash_attention(
            q, k, v,
            mask=attention_mask,
            dropout_p=self.dropout if self.training else 0.0,
            softmax_scale=self.scale,
            causal=is_causal
        )
        
        # Reshape back
        # (batch, heads, seq, head_dim) → (batch, seq, hidden)
        attn_output = attn_output.transpose(1, 2).contiguous()
        attn_output = attn_output.view(batch_size, seq_len, self.hidden_size)
        
