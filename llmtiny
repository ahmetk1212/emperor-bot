"""
Tokenizer Modülleri

Tokenization algoritmaları:
1. BPE (Byte-Pair Encoding): GPT tarzı
2. Unigram: SentencePiece tarzı
3. Char-Level: En basit

Tasarım Kararları:
- HuggingFace tokenizers library kullanımı (hızlı, optimize)
- Custom implementasyon + wrapper
- Caching desteği
"""

import json
from pathlib import Path
from typing import List, Optional, Union, Dict, Any
import torch


class TokenizerWrapper:
    """
    Tokenizer için abstract interface.
    
    Tüm tokenizer'lar bu interface'i implement eder.
    Böylece farklı tokenizer'lar kolayca değiştirilebilir.
    """
    
    @property
    def vocab_size(self) -> int:
        """Vocabulary boyutu."""
        raise NotImplementedError
    
    @property
    def eos_token_id(self) -> int:
        """End-of-sequence token ID."""
        raise NotImplementedError
    
    @property
    def pad_token_id(self) -> int:
        """Padding token ID."""
        raise NotImplementedError
    
    def encode(
        self,
        text: str,
        max_length: Optional[int] = None,
        add_special_tokens: bool = True
    ) -> List[int]:
        """Metni token ID'lerine dönüştür."""
        raise NotImplementedError
    
    def decode(self, ids: List[int], skip_special_tokens: bool = 
True) -> str:
        """Token ID'lerini metne dönüştür."""
        raise NotImplementedError
    
    def batch_encode(
        self,
        texts: List[str],
        max_length: Optional[int] = None,
        padding: bool = True,
        truncation: bool = True
    ) -> Dict[str, torch.Tensor]:
        """Batch encoding."""
        raise NotImplementedError
    
    def batch_decode(
        self,
        batch_ids: List[List[int]],
        skip_special_tokens: bool = True
    ) -> List[str]:
        """Batch decoding."""
        raise NotImplementedError
    
    def save(self, save_dir: Union[str, Path]):
        """Tokenizer'ı kaydet."""
        raise NotImplementedError
    
    @classmethod
    def load(cls, load_dir: Union[str, Path]) -> "TokenizerWrapper":
        """Tokenizer'ı yükle."""
        raise NotImplementedError


class BPETokenizer(TokenizerWrapper):
    """
    Byte-Pair Encoding Tokenizer.
    
    Algoritma:
    1. Metni karakterlere böl
    2. En sık byte pair'i bul
    3. Yeni token olarak ekle
    4. Tekrarla直到 vocab boyutuna ulaşılır
    
    Avantajları:
    - Subword tokenization (out-of-vocabulary için iyı)
    - Türkçe için iyi çalışır (ek, ile, vb.)
    - HuggingFace tokenizers hızlı implementasyon
    
    Args:
        vocab_size: Hedef vocab boyutu
        min_frequency: Minimum token sıklığı
        special_tokens: Özel token listesi
    """
    
    def __init__(
        self,
        vocab_size: int = 30000,
        min_frequency: int = 2,
        special_tokens: Optional[List[str]] = None
    ):
        # HuggingFace tokenizers backend
        try:
            from tokenizers import Tokenizer, models, trainers, 
pre_tokenizers, decoders
            from tokenizers.processors import TemplateProcessing
        except ImportError:
            raise ImportError("tokenizers kütüphanesi gerekli: pip 
install tokenizers")
        
        self.vocab_size = vocab_size
        self.min_frequency = min_frequency
        
        # Default special tokens
        if special_tokens is None:
            special_tokens = ["<unk>", "<pad>", "<s>", "</s>"]
        
        self.special_tokens = special_tokens
        
        # Tokenizer instance
        self._tokenizer = None
        self._is_trained = False
    
    def train(self, files: List[str]):
        """
        Tokenizer'ı eğit.
        
        Args:
            files: Eğitim dosyalarının listesi
        """
        from tokenizers import Tokenizer, models, trainers, 
pre_tokenizers, decoders
        from tokenizers.processors import TemplateProcessing
        
        print(f"BPE Tokenizer eğitimi başlıyor...")
        print(f"  Dosyalar: {len(files)}")
        print(f"  Vocab boyutu: {self.vocab_size}")
        
        # BPE model oluştur
        tokenizer = Tokenizer(models.BPE())
        
        # Pre-tokenizer (whitespace + punctuation)
        tokenizer.pre_tokenizer = pre_tokenizers.Sequence([
            pre_tokenizers.WhitespaceSplit(),
            pre_tokenizers.Punctuation()
        ])
        
        # Trainer
        trainer = trainers.BpeTrainer(
            vocab_size=self.vocab_size,
            min_frequency=self.min_frequency,
            special_tokens=self.special_tokens,
            show_progress=True,
            continuing_subword_prefix="Ġ"  # Byte-level BPE için
        )
        
        # Eğit
        tokenizer.train(files, trainer)
        
        # Decoder
        tokenizer.decoder = decoders.BPEDecoder(suffix="Ġ")
        
        # Post-processor (template processing)
        tokenizer.post_processor = TemplateProcessing(
            single="<s> $A </s>",
            pair="<s> $A </s> </s> $B:1 </s>",
            special_tokens=[
                ("<s>", tokenizer.token_to_id("<s>")),
                ("</s>", tokenizer.token_to_id("</s>"))
            ]
        )
        
        self._tokenizer = tokenizer
        self._is_trained = True
        
        print(f"BPE Tokenizer eğitimi tamamlandı!")
        print(f"  Final vocab boyutu: {tokenizer.get_vocab_size()}")
    
    def train_from_iterator(
        self,
        iterator,
        batched: bool = True,
        len_fn: Optional[callable] = None
    ):
        """
        Iterator'den tokenizer eğit.
        
        Büyük dosyalar için memory-efficient.
        """
        from tokenizers import Tokenizer, models, trainers, 
pre_tokenizers
        
        print(f"BPE Tokenizer iteratör'den eğitimi başlıyor...")
        
