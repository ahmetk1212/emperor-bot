from typing import Optional, Callable, Union
import math


def create_scheduler(
    optimizer: torch.optim.Optimizer,
    scheduler_name: str = "cosine",
    num_training_steps: int = 100000,
    warmup_steps: int = 500,
    warmup_ratio: float = 0.01,
    min_lr_ratio: float = 0.1,
    **kwargs
) -> torch.optim.lr_scheduler._LRScheduler:
    """
    Learning rate scheduler oluştur.
    
    Args:
        optimizer: PyTorch optimizer
        scheduler_name: Scheduler tipi
        num_training_steps: Toplam eğitim adımı
        warmup_steps: Warmup adım sayısı
        warmup_ratio: Alternatif warmup (steps = ratio * total)
        min_lr_ratio: Min LR / initial LR oranı
        **kwargs: Ek parametreler
        
    Returns:
        Scheduler instance
    """
    # Calculate warmup steps
    if warmup_ratio > 0 and warmup_steps == 0:
        warmup_steps = int(warmup_ratio * num_training_steps)
    
    initial_lr = optimizer.param_groups[0]["lr"]
    min_lr = initial_lr * min_lr_ratio
    
    if scheduler_name.lower() == "cosine":
        return CosineAnnealingWarmup(
            optimizer,
            num_training_steps=num_training_steps,
            warmup_steps=warmup_steps,
            min_lr=min_lr
        )
        
    elif scheduler_name.lower() == "linear":
        return LinearWarmupDecay(
            optimizer,
            num_training_steps=num_training_steps,
            warmup_steps=warmup_steps,
            min_lr=min_lr
        )
        
    elif scheduler_name.lower() == "constant":
        return ConstantWarmupScheduler(
            optimizer,
            warmup_steps=warmup_steps
        )
        
    elif scheduler_name.lower() == "polynomial":
        power = kwargs.get("power", 1.0)
        return PolynomialDecay(
            optimizer,
            num_training_steps=num_training_steps,
            warmup_steps=warmup_steps,
            min_lr=min_lr,
            power=power
        )
        
    elif scheduler_name.lower() == "warmup_cosine":
        return WarmupCosineScheduler(
            optimizer,
            num_training_steps=num_training_steps,
            warmup_steps=warmup_steps,
            min_lr=min_lr
        )
        
    else:
        raise ValueError(f"Bilinmeyen scheduler: {scheduler_name}")


class CosineAnnealingWarmup:
    """
    Cosine Annealing with Warmup.
    
    LR Schedule:
    1. Warmup: 0 → initial_lr (linear)
    2. Annealing: initial_lr → min_lr (cosine)
    
    Grafik:
         LR
        1.0 |        ____
            |       /
            |      /
        min |_____/
            |________________ Steps
             warmup    decay
    
    Avantajları:
    - Smooth decay (stable)
    - Warmup (stable başlangıç)
    - LLaMA, GPT-J gibi modellerde kullanılıyor
    
    Referans: Loshchilov & Hutter (SGDR, 2017)
    """
    
    def __init__(
        self,
        optimizer: torch.optim.Optimizer,
        num_training_steps: int,
        warmup_steps: int = 0,
        min_lr: float = 0.0,
        num_cycles: float = 0.5
    ):
        self.optimizer = optimizer
        self.num_training_steps = num_training_steps
        self.warmup_steps = warmup_steps
        self.min_lr = min_lr
        self.num_cycles = num_cycles
        self.current_step = 0
        
        self.base_lrs = [group["lr"] for group in optimizer.param_groups]
    
    def step(self):
        """Scheduler step."""
        self.current_step += 1
        
        lr = self.get_lr()
        
        for param_group, base_lr in zip(self.optimizer.param_groups, 
self.base_lrs):
            param_group["lr"] = lr
    
    def get_lr(self) -> float:
        """Mevcut learning rate'i hesapla."""
        if self.current_step < self.warmup_steps:
            # Linear warmup
            return self.base_lrs[0] * self.current_step / max(1, 
self.warmup_steps)
        
        # Cosine annealing
        progress = (self.current_step - self.warmup_steps) / max(1, 
self.num_training_steps - self.warmup_steps)
        
        cosine_decay = 0.5 * (1.0 + math.cos(math.pi * self.num_cycles * 2.0 
* progress))
        
        return self.min_lr + (self.base_lrs[0] - self.min_lr) * cosine_decay
    
    def state_dict(self):
        """Scheduler state."""
        return {
            "current_step": self.current_step,
            "base_lrs": self.base_lrs
        }
    
    def load_state_dict(self, state_dict):
        """Scheduler state yükle."""
        self.current_step = state_dict["current_step"]
        self.base_lrs = state_dict["base_lrs"]


