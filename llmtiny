"""
Feed-Forward Networks (FFN)

TASARIM KARARLARI:
─────────────────
1. Standard FFN:
   y = W2 @ activation(W1 @ x + b1) + b2
   
2. SwiGLU (LLaMA, Mistral):
   y = W3 @ (Swish(W1 @ x) ⊙ (W2 @ x))
   
   Avantajlar:
   - 3-way gating → daha expressif
   - Swish activation → smooth gradients
   - Bias-free → regularization
   
3. Gated Linear Unit (GLU):
   y = (W1 @ x) ⊙ sigmoid(W2 @ x)
   
Karar: SwiGLU + bias-free (LLaMA tarzı)
- En iyi performance/parameter ratio
- Bias kaldırmak regularization sağlar

Referans: Shazeer (GLU Variants, 2020)
"""

import torch
import torch.nn as nn
import torch.nn.functional as F
from typing import Optional


class SwiGLUFeedForward(nn.Module):
    """
    SwiGLU Feed-Forward Network.
    
    SwiGLU = Swish + Gated Linear Unit
    
    Formül:
        FFN(x) = (W1 @ x) ⊙ Swish(W2 @ x) @ W3
        
    Açılım:
        gate = Swish(W1 @ x)  # Activation ile gate
        value = W3 @ x        # Value
        output = W2 @ (gate ⊙ value)  # Gated activation
        
    Avantajları:
    - 3 projection → ~33% more parameters
    - Genellikle 5-15% better performance
    - Büyük modellerde daha belirgin fayda
    
    Mimari:
    ┌────────────────────────────────────────────────────┐
    │ Input: x (batch, seq, hidden)                     │
    │         ↓                                          │
    │ ┌────────────────────────────────────────────────┐ │
    │ │ W1 @ x → gate_branch                           │ │
    │ │ W3 @ x → value_branch                          │ │
    │ └────────────────────────────────────────────────┘ │
    │         ↓                                          │
    │ ┌────────────────────────────────────────────────┐ │
    │ │ gate = Swish(gate_branch)                       │ │
    │ │ activated = gate ⊙ value_branch                │ │
    │ └────────────────────────────────────────────────┘ │
    │         ↓                                          │
    │ ┌────────────────────────────────────────────────┐ │
    │ │ W2 @ activated → output                        │ │
    │ └────────────────────────────────────────────────┘ │
    │         ↓                                          │
    │ Output: (batch, seq, hidden)                       │
    └────────────────────────────────────────────────────┘
    
    Args:
        hidden_size: Input/output dimension
        intermediate_size: FFN iç boyutu (genellikle 2-4x hidden)
        dropout: Dropout probability
        bias: Use bias in projections (default: False)
    """
    
    def __init__(
        self,
        hidden_size: int,
        intermediate_size: int,
        dropout: float = 0.0,
        bias: bool = False
    ):
        super().__init__()
        
        self.hidden_size = hidden_size
        self.intermediate_size = intermediate_size
        
        # Three projections (no bias for better regularization)
        self.w1 = nn.Linear(hidden_size, intermediate_size, bias=bias)
        self.w2 = nn.Linear(intermediate_size, hidden_size, bias=bias)
        self.w3 = nn.Linear(hidden_size, intermediate_size, bias=bias)
        
        # Dropout
        self.dropout = nn.Dropout(dropout) if dropout > 0 else nn.Identity()
        
        # Swish/Swish activation
        self.act = nn.SiLU()  # Sigmoid-weighted Linear Unit
    
    def forward(self, x: torch.Tensor) -> torch.Tensor:
        """
        Args:
            x: (batch, seq_len, hidden_size)
            
        Returns:
            output: (batch, seq_len, hidden_size)
        """
        # SwiGLU: w1(x) * act(w2(x)) ⊙ w3(x)
        # Alternatif: w1(x) ⊙ act(w2(x)) @ w3
        
        # Gate branch
        gate = self.act(self.w1(x))
        
        # Value branch
        value = self.w3(x)
        
        # SwiGLU
        activated = gate * value
        
        # Dropout
        activated = self.dropout(activated)
        
        # Output projection
        output = self.w2(activated)
        
        return output
    
    def extra_repr(self) -> str:
        return (
            f"hidden_size={self.hidden_size}, "
            f"intermediate_size={self.intermediate_size}"
        )


class GatedLinearUnit(nn.Module):
    """
    Gated Linear Unit (GLU).
    
    Formül:
        y = (W1 @ x + b1) ⊙ sigmoid(W2 @ x + b2)
        
    Variants:
    - Basic GLU: sigmoid gate
    - Bidirectional GLU: x ve reverse(x) kullanır
    - SwishGLU: sigmoid → swish
    
