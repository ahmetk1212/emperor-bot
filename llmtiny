"""
Konfigürasyon Yönetim Sistemi

Tüm hyperparameter'ları merkezi bir yerden yönetir.
YAML dosyalarından yükleme ve kaydetme desteği.

Tasarım Kararları:
- Dataclass tabanlı: Tip güvenliği, IDE desteği
- Default değerler: Küçük model için optimize
- Validation: Otomatik tutarlılık kontrolü
- Computed fields: Otomatik hesaplanan değerler
"""

from dataclasses import dataclass, field, asdict
from typing import List, Optional, Union, Literal
from pathlib import Path
import yaml
import copy


@dataclass
class ModelConfig:
    """
    Model mimari konfigürasyonu.
    
    Scaling notası:
    - hidden_size: Model kapasitesi (büyük = daha expressif)
    - num_layers: Model derinliği (derin = daha abstract)
    - num_heads: Attention head sayısı (çok = daha parallel)
    """
    # === Temel Mimarı ===
    vocab_size: int = 50000          # Token dağarcığı boyutu
    hidden_size: int = 768             # Model embedding boyutu
    num_layers: int = 12              # Transformer katman sayısı
    num_heads: int = 12               # Attention head sayısı
    head_dim: int = 64                # Her head'in dimension'ı
    intermediate_size: int = 3072      # FFN iç boyutu (4x hidden)
    max_seq_length: int = 2048         # Maksimum sequence uzunluğu
    
    # === Hibrit Katman Tipleri ===
    # "mamba" = SSM blokları (hızlı, bellek verimli)
    # "gated_attn" = Hafif gated attention (geçiş katmanları)
    # "flash_attn" = Full attention (global reasoning)
    layer_types: List[str] = field(default_factory=lambda: [
        "mamba", "mamba", "mamba", "mamba",
        "gated_attn", "gated_attn",
        "flash_attn", "flash_attn", "flash_attn", "flash_attn",
        "flash_attn", "flash_attn"
    ])
    
    # === Normalizasyon ===
    norm_type: Literal["rmsnorm", "layernorm"] = "rmsnorm"
    norm_eps: float = 1e-5
    
    # === Aktivasyon ===
    activation: Literal["silu", "gelu", "relu"] = "silu"
    use_swiglu: bool = True           # SwiGLU FFN kullan (LLaMA tarzı)
    
    # === Regularization ===
    dropout: float = 0.0
    attention_dropout: float = 0.0
    
    # === Positional Encoding ===
    pos_emb_type: Literal["rope", "alibi", "learned"] = "rope"
    rope_theta: float = 10000.0        # RoPE base frequency
    rope_max_seq: int = 32768         # RoPE max seq length
    
    # === Initialization ===
    init_std: float = 0.02
    use_bias: bool = False
    
    def __post_init__(self):
        """Validation ve auto-fill."""
        # Head dimension kontrolü
        if self.hidden_size % self.head_dim != 0:
            raise ValueError(
                f"hidden_size ({self.hidden_size}) head_dim ({self.head_dim}) "
                f"ile bölünebilir olmalı"
            )
        
        # Auto-calculate num_heads
        self.num_heads = self.hidden_size // self.head_dim
        
        # Layer types auto-generate
        if len(self.layer_types) != self.num_layers:
            self.layer_types = self._generate_layer_types()
            
    def _generate_layer_types(self) -> List[str]:
        """Katman tiplerini model boyutuna göre oluştur."""
        n = self.num_layers
        n_ssm = max(1, int(n * 0.35))
        n_gated = max(1, int(n * 0.20))
        n_attn = n - n_ssm - n_gated
        
        types = (
            ["mamba"] * n_ssm +
            ["gated_attn"] * n_gated +
            ["flash_attn"] * n_attn
        )
        return types[:n]


