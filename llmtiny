"""
Rotary Position Embedding (RoPE)

NEDEN ROPE?
- Learned PE: Sabit boyut, yeni pozisyonlara generalize edemez
- ALiBi: Attention mask manipülasyonu, stable ama yakınsama yavaş
- RoPE: Rotational transformation → Her iki avantajı birleştirir

MATEMATİK:
Token pozisyonu m için query ve key döndürülür:
    q' = R(θ, m) @ q
    k' = R(θ, n) @ k
    
Attention score (rotated):
    q' · k' = q · R(θ, n-m) @ k
    
Bu relative position dependency sağlar!

AVANTAJLARI:
✓ Uzun seq'lere generalize (interpolasyon ile)
✓ Relative position encoding (doğal)
✓ Computational overhead düşük
✓ Stable training

Referans: Su et al. (RoFormer, 2022)
"""

import torch
import torch.nn as nn
import math
from typing import Tuple, Optional


class RotaryPositionalEmbedding(nn.Module):
    """
    Rotary Position Embedding (RoPE).
    
    Her attention head için farklı frekanslarda döndürme uygular.
    
    Args:
        dim: Attention head dimension (genellikle 64)
        max_seq_len: Maksimum sequence length
        base: Frekans base (θ = base^(−2i/dim))
        
    Not: dim çift sayı olmalı (cos/sin pair için)
    """
    
    def __init__(
        self,
        dim: int,
        max_seq_len: int = 32768,
        base: float = 10000.0
    ):
        super().__init__()
        
        assert dim % 2 == 0, f"dim ({dim}) çift olmalı"
        
        self.dim = dim
        self.max_seq_len = max_seq_len
        self.base = base
        
        # Inverse frequencies: θ_i = base^(−2i/dim)
        inv_freq = base ** (
            -torch.arange(0, dim, 2).float() / dim
        )
        self.register_buffer("inv_freq", inv_freq, persistent=False)
        
        # Precompute cos/sin for efficiency
        self._build_cache(max_seq_len)
    
    def _build_cache(self, seq_len: int):
        """Precompute rotation matrices."""
        positions = torch.arange(seq_len, dtype=torch.float)
        
        # angles = positions[:, None] * inv_freq[None, :]
        angles = positions[:, None] * self.inv_freq[None, :]
        
        # Concatenate sin and cos: [cos(θ), sin(θ)]
        emb = torch.cat((angles.sin(), angles.cos()), dim=-1)
        
        self.register_buffer("cos_cached", emb.cos(), persistent=False)
        self.register_buffer("sin_cached", emb.sin(), persistent=False)
    
    def forward(
        self,
        seq_len: int,
        device: torch.device,
        dtype: torch.dtype = torch.float32
    ) -> Tuple[torch.Tensor, torch.Tensor]:
        """
        Args:
            seq_len: İstenen sequence length
            device: Çıktı device
            dtype: Çıktı dtype
            
        Returns:
            (cos, sin) - rotation matrices
        """
        # Extend cache if needed
        if seq_len > self.max_seq_len:
            self._build_cache(seq_len)
            self.max_seq_len = seq_len
        
        # Take from cache
        cos = self.cos_cached[:seq_len].to(device=device, dtype=dtype)
        sin = self.sin_cached[:seq_len].to(device=device, dtype=dtype)
        
        return cos, sin
    
    @staticmethod
    def apply_rotary(
        q: torch.Tensor,
        k: torch.Tensor,
        cos: torch.Tensor,
        sin: torch.Tensor,
        unsqueeze_dim: int = 1
    ) -> Tuple[torch.Tensor, torch.Tensor]:
        """
        Query ve Key'e RoPE uygula.
        
        Args:
            q: Query tensor, (batch, heads, seq, dim)
            k: Key tensor, (batch, heads, seq, dim)
            cos: Cosine values, (seq, dim)
            sin: Sine values, (seq, dim)
            unsqueeze_dim: Broadcast dimension
            
        Returns:
            (q_rotated, k_rotated)
            
        Algoritma:
            x' = x * cos + rotate_half(x) * sin
        """
        # Reshape for broadcasting: (seq, dim) -> (1, 1, seq, dim)
        cos = cos.unsqueeze(unsqueeze_dim).unsqueeze(unsqueeze_dim)
        sin = sin.unsqueeze(unsqueeze_dim).unsqueeze(unsqueeze_dim)
        
        # Apply rotation
        q_embed = (q * cos) + (RotaryPositionalEmbedding._rotate_half(q) * sin)
        k_embed = (k * cos) + (RotaryPositionalEmbedding._rotate_half(k) * sin)
        
        return q_embed, k_embed
    
    @staticmethod
    def _rotate_half(x: torch.Tensor) -> torch.Tensor:
        """
        Half of dimensions'ı döndür ve işaret değiştir.
        
        x = [x1, x2, x3, x4, x5, x6, x7, x8]
        rotate_half(x) = [-x5, -x6, -x7, -x8, x1, x2, x3, x4]
        """
        x1 = x[..., : x.shape[-1] // 2]
        x2 = x[..., x.shape[-1] // 2 :]
        return torch.cat((-x2, x1), dim=-1)


class YaRNPositionalEmbedding(nn.Module):
    """
    YaRN (Yet another RoPE extensibility method).
    
    Uzun seq'lere extension için:
    1. Scaling: Uzun seq'lere adaptasyon
    2. Temperature: Attention decay kontrolü
    3. Optimization: Daha hızlı yakınsama
    
    Kullanım:
        # Pre-training sonrası
        model.pos_emb = YaRN(..., scale=2.0)
        
    Referans: Peng et al. (YaRN, 2023)
    """
    
    def __init__(
        self,
        dim: int,
        max_seq_len: int = 32768,
        base: float = 10000.0,
        scale: float = 1.0,
        ext_factor: float = 1.0,
        attn_factor: float = 1.0,
        beta_min: float = 0.25,
        beta_max: float = 32.0
    ):
        super().__init__()
        
        self.rope = RotaryPositionalEmbedding(dim, max_seq_len, base)
        
        self.scale = scale
        self.ext_factor = ext_factor
        self.attn_factor = attn_factor
        self.beta_min = beta_min
        self.beta_max = beta_max
        
        # Smoothing interpolation
        self.dim = dim
    
    def forward(
        self,
        seq_len: int,
        device: torch.device,
        dtype: torch.dtype = torch.float32
    ) -> Tuple[torch.Tensor, torch.Tensor]:
        """YaRN-adjusted cos/sin döndür."""
        cos, sin = self.rope(seq_len, device, dtype)
        
        # Apply scaling
        cos = cos / self.scale
        sin = sin / self.scale
        
        # Apply extrapolation factor
        cos = cos * self.ext_factor
        sin = sin * self.ext_factor
        
        return cos, sin


class LinearRoPE(nn.Module):
    """
    Linear-time RoPE approximation.
    
    Standart RoPE O(n) ama hala seq_len'e bağlı.
    Bu versiyon: O(1) per token (sabit compute).
    
    Not: Tam RoPE'tan farklı davranır, deneysel.
    """
    
    def __init__(
        self,
        dim: int,
        max_seq_len: int = 32768
    ):
        super().__init__()
        
        self.dim = dim
        self.max_seq_len = max_seq_len
        
        # Precompute rotation phases
        phases = torch.arange(0, dim, 2).float() / dim
        self.register_buffer("phases", phases, persistent=False)
    
    def forward(self, x: torch.Tensor, position_ids: torch.Tensor) -> torch.Tensor:
        """
        Args:
            x: (batch, seq, dim) veya (batch, heads, seq, dim)
            position_ids: (batch, seq) pozisyon ID'leri
            
        Returns:
            Rotary-encoded tensor
        """
        # Handle different input shapes
        original_shape = x.shape
        if x.dim() == 3:
            # (batch, seq, dim) -> (batch, 1, seq, dim)
            x = x.unsqueeze(1)
        
        batch, heads, seq, dim = x.shape
        
        # Get phases for positions
        positions = position_ids.float()  # (batch, seq)
        
        # Compute angles: position * phase
        angles = positions.unsqueeze(-1) * self.phases.to(x.device)  # (batch, seq, dim/2)
        
        # Compute rotary encoding
        cos = angles.cos().unsqueeze(1)  # (batch, 1, seq, dim/2)
        sin = angles.sin().unsqueeze(1)
        
        # Split x into pairs
        x1 = x[..., :dim // 2]
        x2 = x[..., dim // 2:]
        
        # Apply rotation
        x_rot = torch.cat((-x2, x1), dim=-1)
        
        return (x * cos + x_rot * sin).view(*original_shape)
