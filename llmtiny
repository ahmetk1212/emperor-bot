        """Tokenizer'ı kaydet."""
        save_dir = Path(save_dir)
        save_dir.mkdir(parents=True, exist_ok=True)
        
        # Save as .model file
        # SentencePiece model zaten dosya olarak kaydediliyor
        print(f"Tokenizer kaydedildi: {save_dir}")
    
