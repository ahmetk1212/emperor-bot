"""
Sampling Strategies for Text Generation

Farklı decoding stratejileri:
1. Greedy - En olası token
2. Temperature - Yaratıcılık kontrolü
3. Top-K - K en olası token arasından seçim
4. Nucleus (Top-P) - Olasılık kütüphanesinin bir kısmından seçim

Tasarım Kararları:
- Modular design: Her strateji ayrı sınıf
- Kombinable: Birden fazla strateji zincirlenebilir
- Batch desteği: Birden fazla prompt paralel işlenebilir
"""

import torch
import torch.nn.functional as F
from typing import Optional, List, Tuple
from abc import ABC, abstractmethod
import numpy as np


class Sampler(ABC):
    """
    Base Sampler class.
    
    Tüm sampling stratejileri bu class'tan türer.
    """
    
    @abstractmethod
    def sample(
        self,
        logits: torch.Tensor,
        temperature: float = 1.0
    ) -> torch.Tensor:
        """
        Sample next token from logits.
        
        Args:
            logits: (vocab_size,) - model logits for next token
            temperature: Sampling temperature
            
        Returns:
            (1,) - Selected token ID
        """
        pass


class GreedySampler(Sampler):
    """
    Greedy Sampling.
    
    Her zaman en olası token'ı seçer.
    Deterministic, reproducible sonuçlar.
    
    Avantajları:
    - En hızlı
    - Deterministic
    Dezavantajları:
    - Tekrarlayan output
    - Yaratıcılık yok
    """
    
    def sample(
        self,
        logits: torch.Tensor,
        temperature: float = 1.0
    ) -> torch.Tensor:
        """Greedy selection - en yüksek logit."""
        return torch.argmax(logits, dim=-1, keepdim=True)


class TemperatureSampler(Sampler):
    """
    Temperature Sampling.
    
    Logits'i temperature ile ölçekler:
    - high temperature (örn 1.5): Daha rastgele, yaratıcı
    - low temperature (örn 0.5): Daha deterministic, tutucu
    
    Formül:
        P(token) = softmax(logits / temperature)
    """
    
    def sample(
        self,
        logits: torch.Tensor,
        temperature: float = 1.0
    ) -> torch.Tensor:
        # Apply temperature
        if temperature != 1.0:
            logits = logits / temperature
        
        # Softmax + sample
        probs = F.softmax(logits, dim=-1)
        return torch.multinomial(probs, num_samples=1)


class TopKSampler(Sampler):
    """
    Top-K Sampling.
    
    En olası K token arasından seçim yapar.
    Repetition'u azaltır, ama bazen çok dar veya çok geniş olabilir.
    
    Args:
        k: Kaç en iyi token consideration'da
    """
    
    def __init__(self, k: int = 50):
        self.k = k
    
    def sample(
        self,
        logits: torch.Tensor,
        temperature: float = 1.0
    ) -> torch.Tensor:
        # Apply temperature
        if temperature != 1.0:
            logits = logits / temperature
        
        # Top-K
        top_k_values, top_k_indices = torch.topk(logits, min(self.k, 
logits.size(-1)))
        
        # Mask others
        filtered_logits = torch.full_like(logits, float('-inf'))
        filtered_logits.scatter_(1, top_k_indices, top_k_values)
        
        # Sample
        probs = F.softmax(filtered_logits, dim=-1)
        return torch.multinomial(probs, num_samples=1)


class NucleusSampler(Sampler):
    """
    Nucleus (Top-P) Sampling.
    
    En olası token'ları cumulative probability'e göre seçer.
    Kullanışlı: Her zaman en uygun token sayısını seçer.
    
    Örnek:
    - P(token) = [0.5, 0.3, 0.1, 0.05, 0.05]
    - Top-P = 0.9
    - İlk 3 token seçilir (0.5 + 0.3 + 0.1 = 0.9 >= 0.9)
    
    Args:
        p: Cumulative probability threshold (0 < p <= 1)
    """
    
    def __init__(self, p: float = 0.95):
        self.p = p
    
    def sample(
        self,
        logits: torch.Tensor,
        temperature: float = 1.0
    ) -> torch.Tensor:
        # Apply temperature
        if temperature != 1.0:
            logits = logits / temperature
        
        # Softmax
        probs = F.softmax(logits, dim=-1)
        
        # Sort
        sorted_probs, sorted_indices = torch.sort(probs, descending=True)
        
        # Cumulative sum
        cumsum_probs = torch.cumsum(sorted_probs, dim=-1)
        
        # Find cutoff
        cumsum_mask = cumsum_probs <= self.p
        
        # Always include at least one token
        cumsum_mask[..., 0] = True
        
        # Get number of tokens to keep
        num_tokens = cumsum_mask.sum(dim=-1)
        
        # Create mask for top-p tokens
        mask = torch.zeros_like(probs, dtype=torch.bool)
        for i, n in enumerate(num_tokens):
            mask[i, sorted_indices[i, :n]] = True
        
        # Apply mask
        filtered_probs = torch.where(mask, probs, torch.zeros_like(probs))
        
        # Renormalize
        filtered_probs = filtered_probs / filtered_probs.sum(dim=-1, 
keepdim=True)
        
        # Sample
        return torch.multinomial(filtered_probs, num_samples=1)


class RepetitionPenaltySampler(Sampler):
    """
    Repetition Penalty.
    
    Daha önce görülen token'ların olasılığını azaltır.
    Uzun output'larda repetition'ı engeller.
    
    Formül:
        logits[seen_token] /= penalty
        
    Args:
        penalty: > 1.0 azaltır, < 1.0 artırır
    """
    
    def __init__(self, penalty: float = 1.2, base_sampler: Optional[Sampler] 
= None):
        self.penalty = penalty
        self.base_sampler = base_sampler or 
TemperatureSampler(temperature=1.0)
    
    def sample(
        self,
        logits: torch.Tensor,
        temperature: float = 1.0,
        seen_tokens: Optional[List[int]] = None
    ) -> torch.Tensor:
        if seen_tokens and self.penalty != 1.0:
            for token in seen_tokens:
                logits[token] = logits[token] / self.penalty
        
        return self.base_sampler.sample(logits, temperature)


class CompositeSampler(Sampler):
    """
    Composite Sampler.
    
    Birden fazla sampling stratejisini birleştirir.
    
    Args:
        samplers: Liste of Sampler instances
        weights: Her sampler'ın ağırlığı (opsiyonel)
    """
    
    def __init__(
        self,
        samplers: List[Sampler],
        weights: Optional[List[float]] = None
    ):
        self.samplers = samplers
        
        if weights is None:
            weights = [1.0 / len(samplers)] * len(samplers)
        
        self.weights = weights
    
    def sample(
        self,
        logits: torch.Tensor,
        temperature: float = 1.0
    ) -> torch.Tensor:
        # Get probabilities from each sampler
        all_probs = []
        
        for sampler in self.samplers:
            # Get logits for each sampler
            sampled_token = sampler.sample(logits.clone(), temperature)
            
            # Convert to one-hot
            one_hot = F.one_hot(sampled_token, 
num_classes=logits.size(-1)).float()
            all_probs.append(one_hot)
        
        # Weighted average (probability distribution)
        avg_probs = sum(w * p for w, p in zip(self.weights, all_probs))
        
        # Sample from combined distribution
        return torch.multinomial(avg_probs.squeeze(1), num_samples=1)
