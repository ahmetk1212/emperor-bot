        # Büyük init → Large logits → Hot tokens
        # Küçük init → Stable başlangıç
        # Burada standart init kullanıyoruz (lm_head ayrı init alacak)
    
    def forward(self, input_ids: torch.Tensor) -> torch.Tensor:
        """
        Args:
            input_ids: (batch_size, seq_len) token ID'leri
            
        Returns:
            embeddings: (batch_size, seq_len, hidden_size)
        """
        return torch.embedding(self.weight, input_ids)
    
    def extra_repr(self) -> str:
        return (
            f"vocab_size={self.vocab_size}, "
            f"hidden_size={self.hidden_size}, "
            f"padding_idx={self.padding_idx}"
        )


class LearnedPositionalEmbedding(nn.Module):
    """
    Learned Positional Embedding.
    
    Alternatif: RoPE (daha iyi)
    Bu: Geriye uyumluluk için tutuluyor.
    
    Args:
        max_seq_length: Maksimum pozisyon
        hidden_size: Embedding boyutu
    """
    
    def __init__(
        self,
        max_seq_length: int,
        hidden_size: int,
        init_std: float = 0.02
    ):
        super().__init__()
        
        self.max_seq_length = max_seq_length
        self.hidden_size = hidden_size
        
        self.weight = nn.Parameter(
            torch.empty(max_seq_length, hidden_size)
        )
        
        nn.init.normal_(self.weight, mean=0.0, std=init_std)
    
    def forward(self, position_ids: torch.Tensor) -> torch.Tensor:
        """
        Args:
            position_ids: (batch_size, seq_len) pozisyon ID'leri
            
        Returns:
            position_embeddings: (batch_size, seq_len, hidden_size)
        """
        return torch.embedding(self.weight, position_ids)
    
    def extend(self, new_max_length: int):
        """Yeni pozisyonlar için embedding'leri genişlet."""
        if new_max_length <= self.max_seq_length:
            return
        
        old_weight = self.weight.data
        new_weight = torch.empty(new_max_length, self.hidden_size)
        
        # Copy old embeddings
        new_weight[:self.max_seq_length] = old_weight
        
        # Initialize new embeddings
        nn.init.normal_(new_weight[self.max_seq_length:], std=0.02)
        
        self.weight = nn.Parameter(new_weight)
        self.max_seq_length = new_max_length


