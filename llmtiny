"""
Optimizer Modülleri

Farklı optimizer implementasyonları:
1. AdamW - Standart, güvenilir
2. Sophia - Daha hızlı yakınsama
3. Lion - Daha az bellek

Tasarım Kararları:
- PyTorch native optimizer'lar wrapper'lanmış
- Custom optimizer'lar için base class
- Learning rate ve weight decay ayrı yönetimi
"""

import torch
import torch.nn as nn
import torch.optim as optim
from torch.optim.optimizer import Optimizer
from typing import Dict, List, Optional, Callable, Any
from collections import defaultdict
import math


def create_optimizer(
    model: nn.Module,
    optimizer_name: str = "adamw",
    learning_rate: float = 3e-4,
    weight_decay: float = 0.1,
    beta1: float = 0.9,
    beta2: float = 0.999,
    eps: float = 1e-8,
    **kwargs
) -> torch.optim.Optimizer:
    """
    Model için optimizer oluştur.
    
    Args:
        model: PyTorch model
        optimizer_name: "adamw", "adam", "sgd", "sophia", "lion"
        learning_rate: Öğrenme hızı
        weight_decay: Ağırlık azaltma
        beta1: Adam beta1
        beta2: Adam beta2
        eps: Numerical stability epsilon
        **kwargs: Ek optimizer parametreleri
        
    Returns:
        Optimizer instance
    """
    # Separate parameters for weight decay
    # LayerNorm, Bias ve embedding'ler decay edilmez
    decay_params = []
    no_decay_params = []
    
    for name, param in model.named_parameters():
        if not param.requires_grad:
            continue
            
        # No decay for these parameters
        if "bias" in name or "LayerNorm" in name or "layernorm" in 
name.lower():
            no_decay_params.append(param)
        elif "norm" in name.lower():
            no_decay_params.append(param)
        elif "embedding" in name.lower():
            no_decay_params.append(param)
        else:
            decay_params.append(param)
    
    # Create optimizer groups
    optimizer_groups = [
        {"params": decay_params, "weight_decay": weight_decay},
        {"params": no_decay_params, "weight_decay": 0.0}
    ]
    
    if optimizer_name.lower() == "adamw":
        optimizer = torch.optim.AdamW(
            optimizer_groups,
            lr=learning_rate,
            betas=(beta1, beta2),
            eps=eps
        )
        
    elif optimizer_name.lower() == "adam":
        optimizer = torch.optim.Adam(
            optimizer_groups,
            lr=learning_rate,
            betas=(beta1, beta2),
            eps=eps
        )
        
    elif optimizer_name.lower() == "sgd":
        optimizer = torch.optim.SGD(
            optimizer_groups,
            lr=learning_rate,
            momentum=beta1,
            weight_decay=0.0  # Already in groups
        )
        
    elif optimizer_name.lower() == "sophia":
        optimizer = SophiaOptimizer(
            optimizer_groups,
            lr=learning_rate,
            beta=beta1,
            rho=kwargs.get("rho", 0.04),
            eps=eps
        )
        
    elif optimizer_name.lower() == "lion":
        optimizer = LionOptimizer(
            optimizer_groups,
            lr=learning_rate,
            beta1=beta1,
            beta2=beta2,
            weight_decay=weight_decay
        )
        
    else:
        raise ValueError(f"Bilinmeyen optimizer: {optimizer_name}")
    
    return optimizer


class AdamWOptimizer:
    """
    AdamW Wrapper - Standart optimizer.
    
    Adam + Weight Decay regularization.
    Transformer eğitimi için default choice.
    """
    
    def __init__(
        self,
        model: nn.Module,
        lr: float = 3e-4,
        weight_decay: float = 0.1,
        beta1: float = 0.9,
        beta2: float = 0.999,
        eps: float = 1e-8
    ):
        self.optimizer = create_optimizer(
            model,
            optimizer_name="adamw",
            learning_rate=lr,
            weight_decay=weight_decay,
            beta1=beta1,
            beta2=beta2,
            eps=eps
        )
        
        self.model = model
        self.lr = lr
        
    def step(self):
        """Optimizer step."""
        self.optimizer.step()
        
    def zero_grad(self):
        """Gradient'leri sıfırla."""
        self.optimizer.zero_grad()
        
    def get_lr(self) -> float:
        """Mevcut learning rate."""
        return self.optimizer.param_groups[0]["lr"]
    
    def set_lr(self, lr: float):
        """Learning rate ayarla."""
        for group in self.optimizer.param_groups:
            group["lr"] = lr
    
    def state_dict(self):
        """Optimizer state."""
        return self.optimizer.state_dict()
    
    def load_state_dict(self, state_dict):
        """Optimizer state yükle."""
        self.optimizer.load_state_dict(state_dict)


class SophiaOptimizer(Optimizer):
    """
    Sophia Optimizer - Daha hızlı yakınsama.
    
    Sophia: Second-order Clipped Stochastic Optimizer
    
    Adam'dan farkı:
    - Hessian diagonal'ını tahmin eder
    - Gradient'leri klipler (numerical stability)
    - Daha az çağrı ile yakınsama
    
    Referans: Liu et al. (Sophia, 2023)
    
    Not: Experimental, bazen unstable olabilir.
    """
    
    def __init__(
        self,
        params,
        lr: float = 1e-3,
        beta: float = 0.9,
        rho: float = 0.04,
        eps: float = 1e-8
    ):
        if not 0.0 <= lr:
            raise ValueError(f"Invalid learning rate: {lr}")
        if not 0.0 <= beta < 1.0:
            raise ValueError(f"Invalid beta: {beta}")
        if not 0.0 <= rho:
            raise ValueError(f"Invalid rho: {rho}")
        if not 0.0 <= eps:
            raise ValueError(f"Invalid epsilon: {eps}")
            
        defaults = dict(
            lr=lr,
            beta=beta,
            rho=rho,
            eps=eps
        )
        
        super().__init__(params, defaults)
    
    def __setstate__(self, state):
        super().__setstate__(state)
    
    @torch.no_grad()
    def step(self, closure: Callable = None):
        """Single optimization step."""
        loss = None
        if closure is not None:
            with torch.enable_grad():
                loss = closure()
        
        for group in self.param_groups:
            params_with_grad = []
            grads = []
            exp_avgs = []
            exp_avg_sqs = []
            state_steps = []
            
            for p in group["params"]:
                if p.grad is None:
                    continue
                    
                params_with_grad.append(p)
                grads.append(p.grad)
                
                state = self.state[p]
                
                # State initialization
                if len(state) == 0:
                    state["step"] = 0
                    state["exp_avg"] = torch.zeros_like(p)
                    state["exp_avg_sq"] = torch.zeros_like(p)
                
                exp_avgs.append(state["exp_avg"])
                exp_avg_sqs.append(state["exp_avg_sq"])
                state_steps.append(state["step"])
            
            beta = group["beta"]
            rho = group["rho"]
            eps = group["eps"]
            lr = group["lr"]
            
            # Sophia update
            for i, param in enumerate(params_with_grad):
                grad = grads[i]
                exp_avg = exp_avgs[i]
                exp_avg_sq = exp_avg_sqs[i]
                step = state_steps[i]
                
                # Update biased moments
                exp_avg.mul_(beta).add_(grad, alpha=1 - beta)
                exp_avg_sq.addcmul_(grad, grad.conj(), value=1 - beta)
                
                step += 1
                
                # Compute update
                denom = exp_avg_sq.sqrt().add_(eps)
                bias_correction1 = 1 - beta ** step
                bias_correction2 = 1 - beta ** step
                
                step_size = lr / bias_correction1
                
                # Sophia: clip gradient
                uncliped_update = exp_avg / denom
                clipped_update = torch.clamp(
                    uncliped_update,
                    min=-rho,
                    max=rho
                )
                
                # Update
                param.add_(clipped_update, alpha=-step_size)
        
        return loss


class LionOptimizer(Optimizer):
    """
    Lion Optimizer - Daha az bellek.
    
    Lion: Learnable Informed Optimizer
    
    Adam'dan farkı:
