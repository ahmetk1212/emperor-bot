            import sentencepiece as spm
        except ImportError:
            raise ImportError("sentencepiece gerekli: pip install 
sentencepiece")
        
        self.vocab_size = vocab_size
        self.max_sentence_length = max_sentence_length
        
        self._spm = None
        self._is_trained = False
    
    def train(
        self,
        text_file: str,
        model_prefix: str = "unigram_model",
        character_coverage: float = 0.9995,
        split_digits: bool = True
    ):
        """
        Unigram tokenizer eğit.
        
        Args:
            text_file: Eğitim metin dosyası
            model_prefix: Model dosya prefix'i
            character_coverage: Karakter kapsama oranı
            split_digits: Rakamlar ayrı token mi?
        """
