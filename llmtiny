"""
Distributed Training Utilities

Multi-GPU ve multi-node training için yardımcı fonksiyonlar.
"""

import os
import torch
import torch.distributed as dist
from typing import Optional
import socket
import logging


def setup_distributed(
    backend: str = "nccl",
    init_method: str = "env://"
) -> bool:
    """
    Distributed training başlat.
    
    Args:
        backend: "nccl", "gloo", "mpi"
        init_method: Initialization method
        
    Returns:
        Distributed başarılı mı
    """
    if "RANK" not in os.environ:
        # Not distributed
        return False
    
    # Get distributed info
    rank = int(os.environ["RANK"])
    world_size = int(os.environ["WORLD_SIZE"])
    local_rank = int(os.environ.get("LOCAL_RANK", 0))
    
    # Initialize
    if not dist.is_initialized():
        dist.init_process_group(
            backend=backend,
            init_method=init_method,
            world_size=world_size,
            rank=rank
        )
    
    # Set device
    torch.cuda.set_device(local_rank)
    
    return True


def is_distributed() -> bool:
    """Distributed training'de mi?"""
    return dist.is_available() and dist.is_initialized()


def get_rank() -> int:
    """Process rank al."""
    if is_distributed():
        return dist.get_rank()
    return 0


def get_world_size() -> int:
    """Toplam process sayısı al."""
    if is_distributed():
        return dist.get_world_size()
    return 1


def is_main_process() -> bool:
    """Main process mi?"""
    return get_rank() == 0


def get_local_rank() -> int:
    """Local rank al."""
    return int(os.environ.get("LOCAL_RANK", 0))


def barrier():
    """Synchronization barrier."""
    if is_distributed():
        dist.barrier()


def cleanup_distributed():
    """Distributed training'i temizle."""
    if is_distributed():
        dist.destroy_process_group()


def reduce_tensor(tensor: torch.Tensor, op=dist.ReduceOp.SUM) -> 
torch.Tensor:
    """
    Tensor'ı tüm process'lere reduce et.
    
    Args:
        tensor: Reduce edilecek tensor
        op: Reduce operation
        
    Returns:
        Reduced tensor
    """
    if not is_distributed():
        return tensor
    
    tensor = tensor.clone()
    dist.all_reduce(tensor, op=op)
    
    return tensor


def gather_tensor(tensor: torch.Tensor) -> torch.Tensor:
    """
    Tensor'ı gather et.
    
    Args:
        tensor: Gather edilecek tensor
        
    Returns:
        Gathered tensor (world_size, *tensor.shape)
    """
    if not is_distributed():
        return tensor.unsqueeze(0)
    
    world_size = get_world_size()
    
    # Gather sizes
    local_size = torch.tensor(tensor.size(), device=tensor.device)
    sizes = [torch.zeros_like(local_size) for _ in range(world_size)]
    dist.all_gather(sizes, local_size)
    
    # Gather tensors
    max_size = max(s.size() for s in sizes)
    padded = torch.zeros(max_size.tolist(), device=tensor.device, 
dtype=tensor.dtype)
    padded[:tensor.size(0)] = tensor
    
    gathered = [torch.zeros_like(padded) for _ in range(world_size)]
    dist.all_gather(gathered, padded)
    
    return torch.stack(gathered)


class DistributedSampler:
    """Simple distributed sampler."""
    
    def __init__(self, dataset_size: int, shuffle: bool = True, seed: int = 
42):
        self.dataset_size = dataset_size
        self.shuffle = shuffle
        self.seed = seed
        
        self.rank = get_rank()
        self.world_size = get_world_size()
        
        # Partition dataset
        self.num_samples = dataset_size // self.world_size
        self.start_idx = self.rank * self.num_samples
        self.end_idx = self.start_idx + self.num_samples
    
    def __iter__(self):
        indices = list(range(self.dataset_size))
        
        if self.shuffle:
            import random
            random.seed(self.seed)
            random.shuffle(indices)
        
        indices = indices[self.start_idx:self.end_idx]
        
        return iter(indices)
    
    def __len__(self):
        return self.num_samples
