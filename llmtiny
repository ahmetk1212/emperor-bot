        self.dropout = nn.Dropout(dropout) if dropout > 0 else nn.Identity()
    
    def forward(self, x: torch.Tensor) -> torch.Tensor:
        """
        Args:
            x: (batch, seq_len, hidden_size)
            
        Returns:
            output: (batch, seq_len, intermediate_size)
        """
        gate = self.act(self.w1(x))
        value = self.w2(x)
        
        output = gate * value
        output = self.dropout(output)
        
        return output


class ParallelSwiGLU(nn.Module):
    """
    Parallel SwiGLU (Tensor Parallelism için optimize).
    
    Memory efficiency için:
    - Tüm computation'u tek pass'te yap
    - Ara sonuçları saklama
    
    Aynı mathematical output, farklı implementation.
    """
    
    def __init__(
        self,
        hidden_size: int,
        intermediate_size: int,
        dropout: float = 0.0,
        bias: bool = False
    ):
        super().__init__()
        
        # Combined projection for efficiency
        self.w123 = nn.Linear(hidden_size, intermediate_size * 3, bias=bias)
        
        # Output
        self.out = nn.Linear(intermediate_size, hidden_size, bias=bias)
        
        self.dropout = nn.Dropout(dropout) if dropout > 0 else nn.Identity()
        self.act = nn.SiLU()
    
    def forward(self, x: torch.Tensor) -> torch.Tensor:
        """Tek pass'te SwiGLU."""
        # Parallel projection
        w1x, w2x, w3x = self.w123(x).chunk(3, dim=-1)
        
        # SwiGLU computation
        output = self.out(self.act(w1x) * w3x * torch.sigmoid(w2x))
        
        return self.dropout(output)


class ExpertFeedForward(nn.Module):
    """
    Mixture of Experts (MoE) Feed-Forward.
    
    KULLANIM SENARYOSU:
    - Çok büyük modeller (1B+ parametre)
    - Sparsely activated experts
    - Her token farklı uzmanlar tarafından işlenir
    
    Hardware avantajları:
    - Better throughput
    - More parameters with same compute
    - Communication overhead (distributed)
    
    Not: Bu basitleştirilmiş implementasyon.
    Full MoE: Top-K selection, capacity factor, auxiliary loss, expert dropping.
    
    Referans: Fedus et al. (Switch Transformers, 2022)
    """
    
    def __init__(
        self,
        hidden_size: int,
        intermediate_size: int,
        num_experts: int = 8,
        top_k: int = 2,
        dropout: float = 0.0
    ):
        super().__init__()
        
        self.hidden_size = hidden_size
        self.intermediate_size = intermediate_size
        self.num_experts = num_experts
        self.top_k = top_k
        
        # Router: Hangi expert'lerin kullanılacağına karar verir
        self.router = nn.Linear(hidden_size, num_experts, bias=False)
        
        # Experts: Her biri bağımsız SwiGLU
        self.experts = nn.ModuleList([
            SwiGLUFeedForward(
                hidden_size=hidden_size,
                intermediate_size=intermediate_size,
                dropout=dropout
            )
            for _ in range(num_experts)
        ])
        
        # Aux loss için weight
        self.expert_capacity = 4  # Her expert'in max capacity'si
    
    def forward(self, x: torch.Tensor) -> torch.Tensor:
        """
        Args:
            x: (batch, seq_len, hidden_size)
            
        Returns:
            output: (batch, seq_len, hidden_size)
        """
        batch_size, seq_len, hidden_size = x.shape
        
        # Flatten
        x_flat = x.view(-1, hidden_size)  # (batch*seq, hidden)
        
        # Router logits
        router_logits = self.router(x_flat)  # (batch*seq, num_experts)
        router_probs = F.softmax(router_logits, dim=-1)
        
        # Top-K selection
        top_k_probs, top_k_indices = torch.topk(
            router_probs, self.top_k, dim=-1
        )
        
        # Normalize top-k
        top_k_probs = top_k_probs / top_k_probs.sum(dim=-1, keepdim=True)
        
        # Initialize output
        output_flat = torch.zeros_like(x_flat)
        
        # Process each expert
        for k in range(self.top_k):
            expert_idx = top_k_indices[:, k]  # (batch*seq,)
            expert_weight = top_k_probs[:, k].unsqueeze(-1)  # (batch*seq, 1)
            
            # Group by expert
            for e in range(self.num_experts):
                mask = expert_idx == e
                if mask.any():
                    expert_input = x_flat[mask]
                    expert_output = self.experts[e](expert_input)
                    output_flat[mask] += expert_output * expert_weight[mask]
        
        return output_flat.view(batch_size, seq_len, hidden_size)
    
    def aux_loss(self, router_probs: torch.Tensor, top_k_indices: torch.Tensor) -> 
torch.Tensor:
        """
        Auxiliary load balancing loss.
        
        Expert'lerin dengeli kullanılmasını sağlar.
        
        Loss = sum_i( load_i / capacity ) / num_experts
        """
        batch_size, seq_len = top_k_indices.shape[:2]
        
        # Expert usage counts
        usage = torch.zeros(
            self.num_experts,
            device=top_k_indices.device,
            dtype=torch.float
        )
        
        for i in range(self.top_k):
            indices = top_k_indices[:, :, i].flatten()
            counts = torch.bincount(indices, minlength=self.num_experts)
            usage += counts.float()
        
        # Load balancing
        usage = usage / (batch_size * seq_len * self.top_k)
        
        # Auxiliary loss
        aux_loss = self.num_experts * (usage ** 2).mean()
        
        return aux_loss
