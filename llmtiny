            raise ValueError("Tokenizer eğitilmemiş!")
        
        encoding = self._tokenizer.encode(
            text,
            add_special_tokens=add_special_tokens
        )
        
        ids = list(encoding.ids)
        
        # Truncate
        if truncation and max_length and len(ids) > max_length:
            ids = ids[:max_length]
        
        return ids
    
    def decode(self, ids: List[int], skip_special_tokens: bool = 
True) -> str:
        """Token ID'leri decode et."""
        if self._tokenizer is None:
            raise ValueError("Tokenizer eğitilmemiş!")
        
        return self._tokenizer.decode(ids, 
skip_special_tokens=skip_special_tokens)
    
    def batch_encode(
        self,
        texts: List[str],
        max_length: Optional[int] = None,
        padding: bool = True,
        truncation: bool = True
    ) -> Dict[str, torch.Tensor]:
        """Batch encoding."""
        if self._tokenizer is None:
            raise ValueError("Tokenizer eğitilmemiş!")
        
        encodings = self._tokenizer.encode_batch(texts)
        
        # Pad/truncate
        if max_length:
            for enc in encodings:
                if len(enc.ids) > max_length:
                    enc.ids = enc.ids[:max_length]
                    enc.attention_mask = 
enc.attention_mask[:max_length]
                elif padding and len(enc.ids) < max_length:
                    pad_id = self.pad_token_id
                    enc.ids = enc.ids + [pad_id] * (max_length - 
len(enc.ids))
                    enc.attention_mask = enc.attention_mask + [0] * 
(max_length - len(enc.attention_mask))
        
        # Stack
        input_ids = torch.tensor([e.ids for e in encodings], 
dtype=torch.long)
        attention_mask = torch.tensor([e.attention_mask for e in 
encodings], dtype=torch.long)
        
        return {
            "input_ids": input_ids,
            "attention_mask": attention_mask
        }
    
    def batch_decode(
        self,
        batch_ids: List[List[int]],
        skip_special_tokens: bool = True
    ) -> List[str]:
