    vocab_size = model.config.vocab_size
    
    input_ids = torch.randint(0, vocab_size, (batch_size, seq_len))
    
    with torch.no_grad():
        output = model(input_ids)
    
    assert "logits" in output
    assert output["logits"].shape == (batch_size, seq_len, 
vocab_size)
