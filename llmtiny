        print(f"Unigram Tokenizer eğitimi başlıyor...")
        print(f"  Eğitim dosyası: {text_file}")
        print(f"  Vocab boyutu: {self.vocab_size}")
        
        # Train command
        spm.SentencePieceTrainer.train(
            input=text_file,
            model_prefix=model_prefix,
            vocab_size=self.vocab_size,
            character_coverage=character_coverage,
            max_sentence_length=self.max_sentence_length,
            split_digits=split_digits,
            unk_id=0,
            bos_id=1,
            eos_id=2,
            pad_id=3,
            model_type="unigram",
            train_extremely_large_vocab=True,
            input_sentence_size=10000000,
            shuffle_input_sentence=True
        )
        
        # Load model
        self._spm = spm.SentencePieceProcessor()
        self._spm.load(f"{model_prefix}.model")
        self._is_trained = True
        
        print(f"Unigram Tokenizer eğitimi tamamlandı!")
        print(f"  Vocab boyutu: {self._spm.get_piece_size()}")
    
    @property
    def vocab_size_property(self) -> int:
        if self._spm is None:
            return 0
        return self._spm.get_piece_size()
    
    @property
    def eos_token_id(self) -> int:
        return 2
    
    @property
    def pad_token_id(self) -> int:
        return 3
    
    def encode(
        self,
        text: str,
        max_length: Optional[int] = None,
        add_special_tokens: bool = True
    ) -> List[int]:
        """Metni encode et."""
        if self._spm is None:
            raise ValueError("Tokenizer eğitilmemiş!")
        
        ids = self._spm.encode(text)
        
        if max_length and len(ids) > max_length:
            ids = ids[:max_length]
        
        return ids
    
    def decode(self, ids: List[int], skip_special_tokens: bool = 
True) -> str:
        """Token ID'leri decode et."""
        if self._spm is None:
            raise ValueError("Tokenizer eğitilmemiş!")
        
        return self._spm.decode(ids)
    
    def batch_encode(
        self,
        texts: List[str],
        max_length: Optional[int] = None,
        padding: bool = True,
        truncation: bool = True
    ) -> Dict[str, torch.Tensor]:
        """Batch encoding."""
        input_ids = []
        attention_masks = []
        max_len = 0
        
        for text in texts:
            ids = self.encode(text, max_length=max_length)
            max_len = max(max_len, len(ids))
            input_ids.append(ids)
        
        if padding and max_length is None:
            max_length = max_len
        
        # Pad
        for i, ids in enumerate(input_ids):
            if padding and max_length:
                pad_len = max_length - len(ids)
                ids = ids + [self.pad_token_id] * pad_len
                mask = [1] * (max_length - pad_len) + [0] * pad_len
            else:
                mask = [1] * len(ids)
            
            input_ids[i] = ids
            attention_masks.append(mask)
        
        return {
            "input_ids": torch.tensor(input_ids, dtype=torch.long),
            "attention_mask": torch.tensor(attention_masks, 
dtype=torch.long)
        }
    
    def batch_decode(
        self,
        batch_ids: List[List[int]],
        skip_special_tokens: bool = True
    ) -> List[str]:
        """Batch decoding."""
        return [self.decode(ids) for ids in batch_ids]
    
