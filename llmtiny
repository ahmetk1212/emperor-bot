def create_dataloaders(
    train_dataset,
    val_dataset,
    tokenizer: Any,
    batch_size: int = 8,
    max_length: int = 2048,
    num_workers: int = 4,
    collator_type: str = "pretraining"
) -> Dict[str, DataLoader]:
    """
    Train ve validation dataloader oluştur.
    
    Args:
        train_dataset: Eğitim dataset'i
        val_dataset: Validation dataset'i
        tokenizer: Tokenizer instance
        batch_size: Batch size
        max_length: Maksimum sequence length
        num_workers: DataLoader worker sayısı
        collator_type: "pretraining", "generation", "dynamic"
        
    Returns:
        {"train": train_loader, "val": val_loader}
    """
    from .collators import (
        PreTrainingCollator,
        GenerationCollator,
        DynamicBatchCollator
    )
    
    # Select collator
    if collator_type == "pretraining":
        collator = PreTrainingCollator(
            tokenizer=tokenizer,
            max_length=max_length
        )
    elif collator_type == "generation":
        collator = GenerationCollator(
            tokenizer=tokenizer,
            max_length=max_length
        )
    elif collator_type == "dynamic":
        collator = DynamicBatchCollator(
            tokenizer=tokenizer,
            max_length=max_length,
            batch_size=batch_size
        )
    else:
        raise ValueError(f"Bilinmeyen collator: {collator_type}")
    
    # Create dataloaders
    train_loader = DataLoader(
        train_dataset,
        batch_size=batch_size,
        shuffle=True,
        num_workers=num_workers,
        collate_fn=collator,
        pin_memory=True,
        persistent_workers=num_workers > 0
    )
    
    val_loader = None
    if val_dataset:
        val_loader = DataLoader(
            val_dataset,
            batch_size=batch_size,
            shuffle=False,
            num_workers=num_workers,
            collate_fn=collator,
            pin_memory=True,
            persistent_workers=num_workers > 0
        )
    
    return {"train": train_loader, "val": val_loader}


