class StreamingTextDataset(IterableDataset):
    """
    Streaming Text Dataset.
    
    Belleğe yüklemez, dosyadan satır satır okur.
    Büyük veri setleri için idealdir.
    
    Args:
        file_path: Metin dosyası yolu
        tokenizer: Tokenizer instance
        max_length: Maksimum token uzunluğu
        buffer_size: Okuma buffer boyutu
    """
    
    def __init__(
        self,
        file_path: str,
        tokenizer: Any,
        max_length: int = 2048,
        min_length: int = 16,
        buffer_size: int = 10000
    ):
        self.file_path = Path(file_path)
        self.tokenizer = tokenizer
        self.max_length = max_length
        self.min_length = min_length
        self.buffer_size = buffer_size
        
        if not self.file_path.exists():
            raise FileNotFoundError(f"Dosya bulunamadı: 
{file_path}")
        
        # Count total lines
        print(f"Dosya satır sayısı hesaplanıyor...")
        with open(self.file_path, "r", encoding="utf-8") as f:
            self.total_lines = sum(1 for _ in f)
        print(f"Toplam satır: {self.total_lines:,}")
    
    def __iter__(self) -> Iterator[Dict[str, torch.Tensor]]:
        """Satır satır oku ve yield et."""
        with open(self.file_path, "r", encoding="utf-8") as f:
            buffer = []
            
            for line in f:
                line = line.strip()
                
                if not line:
                    continue
                
                # Tokenize
                try:
                    encoding = self.tokenizer.encode(
                        line,
                        max_length=self.max_length,
                        add_special_tokens=True
                    )
                except Exception:
                    continue
                
                # Filter
                if len(encoding) < self.min_length:
                    continue
                
                buffer.append({
                    "input_ids": encoding,
                    "length": len(encoding)
                })
                
                # Yield in batches
                if len(buffer) >= self.buffer_size:
                    for item in buffer:
                        yield {
                            "input_ids": 
torch.tensor(item["input_ids"], dtype=torch.long),
                            "length": item["length"]
                        }
                    buffer = []
            
            # Yield remaining
            for item in buffer:
                yield {
                    "input_ids": torch.tensor(item["input_ids"], 
dtype=torch.long),
                    "length": item["length"]
                }
    
    def __len__(self) -> int:
        """Toplam örnek sayısı (yaklaşık)."""
        # Approximate - tam sayı için tüm dosyayı okumak gerekir
        return self.total_lines // 2  # Tahmini


class ConcatDataset(Dataset):
    """
    Concatenated Document Dataset.
    
    Birden fazla metin belgesini tek bir sequence olarak 
birleştirir.
    Belge sınırlarını EOS token ile işaretler.
    
    Eğitim verimliliği için önemli:
    - Her batch dolu olur (padding azalır)
    - Belge içi bağlam korunur
    
    Args:
        texts: Metin listesi
        tokenizer: Tokenizer instance
        max_length: Maksimum sequence uzunluğu
        eos_token_id: Belge sonu token ID
    """
    
    def __init__(
        self,
        texts: List[str],
        tokenizer: Any,
        max_length: int = 2048,
        eos_token_id: int = 2,
        shuffle_documents: bool = False,
        seed: int = 42
    ):
        self.tokenizer = tokenizer
        self.max_length = max_length
        self.eos_token_id = eos_token_id
        
        print(f"Belge concatenation başlıyor... ({len(texts)} 
metin)")
        
        # Tokenize all texts
        print("Tüm metinler tokenize ediliyor...")
        self.tokenized_documents = []
        
        for i, text in enumerate(texts):
            if i % 10000 == 0 and i > 0:
                print(f"  İşlenen: {i:,}/{len(texts):,}")
            
            # Tokenize without special tokens initially
            try:
                encoding = tokenizer.encode(
                    text,
                    max_length=None,  # No truncation
                    add_special_tokens=False
                )
            except Exception:
                continue
            
            if len(encoding) == 0:
                continue
            
            # Add EOS
            encoding.append(eos_token_id)
            self.tokenized_documents.append(encoding)
        
        print(f"Toplam belge: {len(self.tokenized_documents):,}")
        
        # Shuffle if requested
        if shuffle_documents:
            import random
            random.seed(seed)
            random.shuffle(self.tokenized_documents)
        
        # Concatenate all documents
        print("Belge concatenation...")
        self.all_tokens = []
        
        for doc in self.tokenized_documents:
            self.all_tokens.extend(doc)
        
        self.total_tokens = len(self.all_tokens)
        self.total_sequences = (self.total_tokens - 1) // max_length 
+ 1
        
        print(f"Toplam token: {self.total_tokens:,}")
        print(f"Toplam sequence: {self.total_sequences:,}")
    
    def __len__(self) -> int:
        return self.total_sequences
    
    def __getitem__(self, idx: int) -> Dict[str, torch.Tensor]:
        """Sequence döndür."""
        start = idx * self.max_length
        end = start + self.max_length
        
        input_ids = self.all_tokens[start:end]
        labels = self.all_tokens[start + 1:end + 1]  # Shift by 1
        
        # Pad if necessary
        pad_id = self.tokenizer.pad_token_id
        
        if len(input_ids) < self.max_length:
            padding_length = self.max_length - len(input_ids)
            input_ids = input_ids + [pad_id] * padding_length
            labels = labels + [pad_id] * padding_length
        
        return {
            "input_ids": torch.tensor(input_ids, dtype=torch.long),
            "labels": torch.tensor(labels, dtype=torch.long)
        }


