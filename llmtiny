"""
Base Model Sınıfı

Tüm model sınıfları için abstract base.
Interface tanımları ve ortak metodlar.
"""

import torch
import torch.nn as nn
from abc import ABC, abstractmethod
from typing import Dict, Optional, Tuple, Any
from pathlib import Path
import json


class BaseModel(ABC, nn.Module):
    """
    Abstract base class for all NightShade models.
    
    Şunları sağlar:
    - Ortak interface
    - Parametre sayma
    - Device yönetimi
    - Checkpoint formatı
    """
    
    def __init__(self):
        super().__init__()
        self._is_initialized = False
        
    @abstractmethod
    def forward(
        self,
        input_ids: torch.Tensor,
        attention_mask: Optional[torch.Tensor] = None,
        labels: Optional[torch.Tensor] = None,
    ) -> Dict[str, torch.Tensor]:
        """
        Forward pass.
        
        Args:
            input_ids: (batch_size, seq_len)
            attention_mask: (batch_size, seq_len)
            labels: (batch_size, seq_len) - optional
            
        Returns:
            dict with 'logits' and optionally 'loss'
        """
        pass
    
    @property
    @abstractmethod
    def config(self) -> Any:
        """Model konfigürasyonu."""
        pass
    
    @property
    def device(self) -> torch.device:
        """Model'in bulunduğu device."""
        return next(self.parameters()).device
    
    def get_num_params(self, trainable_only: bool = False) -> int:
        """Toplam parametre sayısı."""
        gen = self.parameters() if not trainable_only else self.parameters()
        return sum(p.numel() for p in gen)
    
    def get_num_params_breakdown(self) -> Dict[str, int]:
        """Parametreleri kategoriye göre say."""
        total = 0
        breakdown = {}
        
        for name, module in self.named_modules():
            if len(list(module.children())) > 0:
                continue  # Skip containers
            
            params = sum(p.numel() for p in module.parameters())
            if params > 0:
                breakdown[name] = params
                total += params
                
        breakdown["total"] = total
        return breakdown
    
    def freeze_embeddings(self):
        """Embedding katmanlarını dondur."""
        for param in self.embeddings.parameters():
            param.requires_grad = False
    
    def unfreeze_all(self):
        """Tüm parametreleri aç."""
        for param in self.parameters():
            param.requires_grad = True
    
    def save_checkpoint(self, path: Path, metadata: Optional[Dict] = None):
        """
        Model checkpoint kaydet.
        
        Args:
            path: Kayıt yolu
            metadata: Ek bilgiler (epoch, step, vb.)
        """
        path = Path(path)
        path.parent.mkdir(parents=True, exist_ok=True)
        
        checkpoint = {
            "model_state_dict": self.state_dict(),
            "config": self.config if hasattr(self, "config") else None,
            "metadata": metadata or {},
        }
        
        torch.save(checkpoint, path)
        
    def load_checkpoint(self, path: Path, strict: bool = True) -> Dict:
        """
        Model checkpoint yükle.
        
        Args:
            path: Checkpoint yolu
            strict: Tam eşleşme kontrolü
            
        Returns:
            metadata dict
        """
        checkpoint = torch.load(path, map_location="cpu")
        
        if "model_state_dict" in checkpoint:
            self.load_state_dict(checkpoint["model_state_dict"], strict=strict)
            return checkpoint.get("metadata", {})
        else:
            # Sadece state dict
            self.load_state_dict(checkpoint, strict=strict)
            return {}
    
    def print_summary(self):
        """Model özetini yazdır."""
        total = self.get_num_params()
        trainable = self.get_num_params(trainable_only=True)
        
        print("=" * 60)
        print(f"Model: {self.__class__.__name__}")
        print("=" * 60)
        print(f"Total Parameters: {total:,}")
        print(f"Trainable Parameters: {trainable:,}")
        print(f"Non-trainable Parameters: {total - trainable:,}")
        print(f"Device: {self.device}")
        print("=" * 60)
