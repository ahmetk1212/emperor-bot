        hidden_size: Embedding boyutu
        max_seq_length: Maksimum seq uzunluğu
        padding_idx: Padding token index
        dropout: Dropout oranı
        use_rope: RoPE kullanılsın mı?
        init_std: Init standard deviation
    """
    
    def __init__(
        self,
        vocab_size: int,
        hidden_size: int,
        max_seq_length: int,
        padding_idx: Optional[int] = None,
        dropout: float = 0.0,
        use_rope: bool = True,
        init_std: float = 0.02
    ):
        super().__init__()
        
        self.hidden_size = hidden_size
        self.use_rope = use_rope
        
        # Token embeddings
        self.token_embedding = TokenEmbedding(
            vocab_size=vocab_size,
            hidden_size=hidden_size,
            padding_idx=padding_idx,
            init_std=init_std
        )
        
        # Position embeddings (only if not using RoPE)
        if not use_rope:
            self.position_embedding = LearnedPositionalEmbedding(
                max_seq_length=max_seq_length,
                hidden_size=hidden_size,
                init_std=init_std
            )
        else:
            self.position_embedding = None
        
        # Dropout
        self.dropout = nn.Dropout(dropout) if dropout > 0 else nn.Identity()
    
    def forward(
        self,
        input_ids: torch.Tensor,
        position_ids: Optional[torch.Tensor] = None
    ) -> torch.Tensor:
        """
        Args:
            input_ids: (batch_size, seq_len)
            position_ids: (batch_size, seq_len) - opsiyonel
            
        Returns:
            embeddings: (batch_size, seq_len, hidden_size)
        """
        batch_size, seq_len = input_ids.shape
        
        # Token embeddings
        embeddings = self.token_embedding(input_ids)
        
        # Position embeddings
        if self.position_embedding is not None:
            if position_ids is None:
                position_ids = torch.arange(
                    seq_len,
                    device=input_ids.device,
                    dtype=torch.long
                ).unsqueeze(0).expand(batch_size, -1)
            
            pos_embeds = self.position_embedding(position_ids)
            embeddings = embeddings + pos_embeds
        
        # Dropout
        embeddings = self.dropout(embeddings)
        
        return embeddings
    
    @property
    def weight(self):
        """LM head ile weight tying için."""
        return self.token_embedding.weight
