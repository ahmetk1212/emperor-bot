class LoggingCallback(Callback):
    """
    Logging callback.
    
    Metrics'leri log dosyasına yazar.
    """
    
    def __init__(
        self,
        log_dir: str = "./logs",
        log_steps: int = 10,
        tensorboard: bool = True
    ):
        self.log_dir = Path(log_dir)
        self.log_dir.mkdir(parents=True, exist_ok=True)
        
        self.log_steps = log_steps
        self.tensorboard = tensorboard
        
        self.writer = None
        
        if self.tensorboard:
            try:
                from torch.utils.tensorboard import SummaryWriter
                self.writer = SummaryWriter(self.log_dir)
            except ImportError:
                print("TensorBoard not available, logging to file only")
                self.tensorboard = False
        
        self.step_logs = []
    
    def on_step_end(self, step: int, logs: Optional[Dict] = None):
        if logs is None:
            return
        
        # Log to tensorboard
        if self.writer:
            for key, value in logs.items():
                if isinstance(value, (int, float)):
                    self.writer.add_scalar(key, value, step)
        
        # Store for file logging
        logs["step"] = step
        logs["timestamp"] = time.time()
        self.step_logs.append(logs)
        
        # Write to file periodically
        if step % self.log_steps == 0:
            self._write_logs()
    
    def _write_logs(self):
        """Log dosyasına yaz."""
        log_file = self.log_dir / "training.log"
        
        with open(log_file, "a") as f:
            for log in self.step_logs[-self.log_steps:]:
                step = log.pop("step")
                timestamp = log.pop("timestamp")
                
                metrics_str = " | ".join([f"{k}={v:.4f}" if isinstance(v, 
float) else f"{k}={v}" 
                                          for k, v in log.items()])
                
                f.write(f"Step {step:8d} | {metrics_str}\n")
    
    def on_train_end(self, logs: Optional[Dict] = None):
        if self.writer:
            self.writer.close()
        
        # Final write
        self._write_logs()


class CheckpointCallback(Callback):
    """
    Checkpoint callback.
    
    Düzenli aralıklarla checkpoint kaydeder.
    """
    
    def __init__(
        self,
        checkpoint_manager,
        save_steps: int = 1000,
        save_best: bool = True
    ):
        self.checkpoint_manager = checkpoint_manager
        self.save_steps = save_steps
        self.save_best = save_best
    
    def on_step_end(self, step: int, logs: Optional[Dict] = None):
        # Regular checkpoint
        if step % self.save_steps == 0:
            self.checkpoint_manager.save_checkpoint(
                step=step,
                metrics=logs,
                tags={"type": "periodic"}
            )
        
        # Best checkpoint
        if self.save_best and logs:
            self.checkpoint_manager.save_checkpoint(
                step=step,
                metrics=logs,
                save_best=True
            )


class EarlyStoppingCallback(Callback):
    """
    Early stopping callback.
    
    Metric düzelmediğinde eğitimi durdurur.
    """
    
    def __init__(
        self,
        monitor: str = "loss",
        patience: int = 5,
        min_delta: float = 0.0,
        greater_is_better: bool = False
    ):
        self.monitor = monitor
        self.patience = patience
        self.min_delta = min_delta
        self.greater_is_better = greater_is_better
        
        self.best_value = None
        self.wait = 0
        self.stopped_epoch = 0
        self.should_stop = False
    
    def on_step_end(self, step: int, logs: Optional[Dict] = None):
        if logs is None or self.monitor not in logs:
            return
        
        current_value = logs[self.monitor]
        
        if self.best_value is None:
            self.best_value = current_value
            return
        
        # Check improvement
        if self.greater_is_better:
            improved = current_value > self.best_value + self.min_delta
        else:
            improved = current_value < self.best_value - self.min_delta
        
        if improved:
            self.best_value = current_value
            self.wait = 0
        else:
            self.wait += 1
            
            if self.wait >= self.patience:
                self.should_stop = True
                self.stopped_epoch = step
                print(f"\nEarly stopping! No improvement for {self.patience} 
steps.")


class MemoryTrackingCallback(Callback):
    """
    Memory tracking callback.
    
    GPU/CPU bellek kullanımını loglar.
    """
    
    def __init__(self, log_steps: int = 100):
        self.log_steps = log_steps
    
    def on_step_end(self, step: int, logs: Optional[Dict] = None):
        if step % self.log_steps != 0:
            return
        
        import torch
        
        logs = logs or {}
        
        # GPU memory
        if torch.cuda.is_available():
            allocated = torch.cuda.memory_allocated() / 1024**3  # GB
            reserved = torch.cuda.memory_reserved() / 1024**3
            logs["gpu_allocated_gb"] = round(allocated, 2)
            logs["gpu_reserved_gb"] = round(reserved, 2)
        
        return logs
