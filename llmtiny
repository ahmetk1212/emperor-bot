"""
Text Generation

Text generation ve decoding stratejileri.
"""

import torch
import torch.nn as nn
from typing import List, Optional, Dict, Any, Union, Callable
from tqdm import tqdm
import numpy as np

from .sampler import (
    Sampler, GreedySampler, TemperatureSampler, 
    TopKSampler, NucleusSampler
)


class TextGenerator:
    """
    Text Generator for Language Models.
    
    Özellikler:
    - Çeşitli sampling stratejileri
    - Beam search desteği
    - Batch processing
    - Repetition penalty
    - Length penalties
    
    Args:
        model: Language model
        tokenizer: Tokenizer
        device: Device
    """
    
    def __init__(
        self,
        model: nn.Module,
        tokenizer: Any,
        device: Optional[torch.device] = None
    ):
        self.model = model
        self.tokenizer = tokenizer
        self.device = device or next(model.parameters()).device
        
        # Default samplers
        self.sampler = NucleusSampler(p=0.95)
        self.temperature = 1.0
        self.top_k = 50
        self.top_p = 0.95
        self.repetition_penalty = 1.0
        
        # Generation settings
        self.max_new_tokens = 100
        self.min_new_tokens = 1
        self.eos_token_id = tokenizer.eos_token_id
        self.pad_token_id = tokenizer.pad_token_id or 0
    
    def set_sampling_strategy(
        self,
        strategy: str = "nucleus",
        temperature: float = 1.0,
        top_k: Optional[int] = None,
        top_p: Optional[float] = None
    ):
        """
        Sampling strategy ayarla.
        
        Args:
            strategy: "greedy", "temperature", "top_k", "nucleus"
            temperature: Sampling temperature
            top_k: Top-K value
            top_p: Nucleus threshold
        """
        self.temperature = temperature
        self.top_k = top_k
        self.top_p = top_p
        
        if strategy == "greedy":
            self.sampler = GreedySampler()
        elif strategy == "temperature":
            self.sampler = TemperatureSampler(temperature=temperature)
        elif strategy == "top_k":
            self.sampler = TopKSampler(k=top_k or 50)
        elif strategy == "nucleus":
            self.sampler = NucleusSampler(p=top_p or 0.95)
        else:
            raise ValueError(f"Bilinmeyen strategy: {strategy}")
    
    @torch.no_grad()
    def generate(
        self,
        prompts: Union[str, List[str]],
        max_new_tokens: Optional[int] = None,
        min_new_tokens: Optional[int] = None,
        do_sample: bool = True,
        num_return_sequences: int = 1,
        **kwargs
    ) -> List[str]:
        """
        Text generation.
        
        Args:
            prompts: Prompt text veya listesi
            max_new_tokens: Maksimum üretilecek token sayısı
            min_new_tokens: Minimum üretilecek token sayısı
            do_sample: Sampling kullanılsın mı? (False = greedy)
            num_return_sequences: Her prompt için kaç output
            
        Returns:
            List of generated strings
        """
        # Normalize prompts
        if isinstance(prompts, str):
            prompts = [prompts]
        
        max_new_tokens = max_new_tokens or self.max_new_tokens
        min_new_tokens = min_new_tokens or self.min_new_tokens
        
        # Encode prompts
        all_inputs = []
        for prompt in prompts:
            input_ids = self.tokenizer.encode(
                prompt,
                add_special_tokens=True,
                return_tensors="pt"
            )["input_ids"]
            all_inputs.append(input_ids)
        
        # Pad to same length
        max_len = max(ids.size(1) for ids in all_inputs)
        for i in range(len(all_inputs)):
            if all_inputs[i].size(1) < max_len:
                padding = torch.full(
                    (1, max_len - all_inputs[i].size(1)),
                    self.pad_token_id,
                    dtype=all_inputs[i].dtype
                )
                all_inputs[i] = torch.cat([all_inputs[i], padding], dim=1)
        
        # Stack
        input_ids = torch.cat(all_inputs, dim=0).to(self.device)
        batch_size = input_ids.size(0)
        
        # Model forward pass
        self.model.eval()
        
        generated = []
        finished = torch.zeros(batch_size, dtype=torch.bool, 
device=self.device)
        
        # Generate tokens
        for step in tqdm(range(max_new_tokens), desc="Generating", 
leave=False):
            # Forward
            outputs = self.model(input_ids=input_ids)
            logits = outputs["logits"]
            
            # Get logits for last position
            next_token_logits = logits[:, -1, :] / self.temperature
            
            # Apply repetition penalty
            if self.repetition_penalty != 1.0:
                for i in range(batch_size):
                    for token_id in set(input_ids[i].tolist()):
                        next_token_logits[i, token_id] /= 
self.repetition_penalty
            
            # Apply top-k
            if self.top_k and self.top_k > 0:
                top_k_vals = torch.topk(next_token_logits, self.top_k)[0]
                threshold = top_k_vals[:, -1].unsqueeze(-1)
                next_token_logits = torch.where(
                    next_token_logits < threshold,
                    torch.full_like(next_token_logits, float('-inf')),
                    next_token_logits
                )
            
            # Apply top-p (nucleus)
            if self.top_p and self.top_p < 1.0 and do_sample:
                probs = torch.softmax(next_token_logits, dim=-1)
                sorted_probs, sorted_indices = torch.sort(probs, 
descending=True)
                cumsum = torch.cumsum(sorted_probs, dim=-1)
                
                # Remove tokens with cumulative probability above threshold
                sorted_mask = cumsum > self.top_p
                sorted_mask[..., 1:] = sorted_mask[..., :-1].clone()
                sorted_mask[..., 0] = False
                
                mask = torch.zeros_like(probs, dtype=torch.bool)
                mask.scatter_(1, sorted_indices, sorted_mask)
                next_token_logits[mask] = float('-inf')
            
            # Sample
            if do_sample:
                probs = torch.softmax(next_token_logits, dim=-1)
                next_token = torch.multinomial(probs, num_samples=1)
            else:
                next_token = torch.argmax(next_token_logits, dim=-1, 
keepdim=True)
            
            # Update
            input_ids = torch.cat([input_ids, next_token], dim=1)
            
            # Check EOS
            finished = finished | (next_token.squeeze(-1) == 
self.eos_token_id)
            
            # Stop if all finished
            if finished.all() and step >= min_new_tokens:
                break
        
        # Decode
        results = []
        for i in range(batch_size):
            generated_ids = input_ids[i]
            generated_text = self.tokenizer.decode(
                generated_ids,
                skip_special_tokens=True
            )
            results.append(generated_text)
        
        return results
    
    @torch.no_grad()
    def generate_streaming(
        self,
        prompt: str,
        max_new_tokens: int = 100,
        callback: Optional[Callable[[str], None]] = None,
        **kwargs
    ) -> str:
        """
        Streaming text generation.
        
        Her token üretildiğinde callback çağrılır.
        
        Args:
            prompt: Input prompt
            max_new_tokens: Max tokens
            callback: Her token sonrası çağrılacak fonksiyon
            
        Returns:
            Full generated text
        """
        # Encode
        input_ids = self.tokenizer.encode(
            prompt,
            return_tensors="pt"
        )["input_ids"].to(self.device)
        
        self.model.eval()
        
        generated_text = prompt
        
        for _ in tqdm(range(max_new_tokens), desc="Generating", leave=False):
            # Forward
            outputs = self.model(input_ids=input_ids)
            logits = outputs["logits"]
            
            # Get last token logits
            next_token_logits = logits[:, -1, :] / self.temperature
            
            # Sample
            if self.temperature > 0:
                probs = torch.softmax(next_token_logits, dim=-1)
                next_token = torch.multinomial(probs, num_samples=1)
            else:
                next_token = torch.argmax(next_token_logits, dim=-1, 
keepdim=True)
            
            # Check EOS
            if next_token.item() == self.eos_token_id:
                break
            
            # Decode and append
            token_text = self.tokenizer.decode(next_token[0])
            generated_text += token_text
            
            # Callback
            if callback:
                callback(token_text)
            
            # Update
            input_ids = torch.cat([input_ids, next_token], dim=1)
        
        return generated_text


class BeamSearchGenerator:
    """
    Beam Search Generator.
    
    En iyi N sequence'i paralel takip eder.
    Daha kaliteli output ama daha yavaş.
    
    Args:
        model: Language model
        tokenizer: Tokenizer
        beam_size: Beam sayısı
        length_penalty: Uzunluk cezası
    """
    
    def __init__(
        self,
        model: nn.Module,
        tokenizer: Any,
        beam_size: int = 4,
        length_penalty: float = 1.0,
        device: Optional[torch.device] = None
    ):
        self.model = model
        self.tokenizer = tokenizer
        self.beam_size = beam_size
        self.length_penalty = length_penalty
        self.device = device or next(model.parameters()).device
        
        self.eos_token_id = tokenizer.eos_token_id
    
    @torch.no_grad()
    def generate(
        self,
        prompt: str,
        max_new_tokens: int = 100
    ) -> str:
        """Beam search generation."""
        # Encode
        input_ids = self.tokenizer.encode(
            prompt,
            return_tensors="pt"
        )["input_ids"].to(self.device)
        
        batch_size = input_ids.size(0)
        
        # Initialize beams
        # Each beam: (log_prob, token_ids)
        beams = [(0.0, input_ids)]
        
        self.model.eval()
        
        for step in range(max_new_tokens):
            all_candidates = []
            
            for log_prob, seq in beams:
                # Check if EOS
                if seq[0, -1].item() == self.eos_token_id:
                    all_candidates.append((log_prob, seq))
                    continue
                
                # Forward
                outputs = self.model(input_ids=seq)
                logits = outputs["logits"]
                
                # Get last token logits
                next_logits = logits[0, -1, :]
                
                # Log probabilities
                log_probs = torch.log_softmax(next_logits, dim=-1)
                
                # Top beam_size
                top_log_probs, top_indices = log_probs.topk(self.beam_size)
                
                # Add to candidates
                for i in range(self.beam_size):
                    new_log_prob = log_prob + top_log_probs[i].item()
                    new_seq = torch.cat([seq, 
top_indices[i].unsqueeze(0).unsqueeze(0)], dim=1)
                    all_candidates.append((new_log_prob, new_seq))
            
            # Select top beam_size
            all_candidates.sort(key=lambda x: x[0], reverse=True)
            
            # Apply length penalty
            if self.length_penalty != 1.0:
                scored = []
                for log_prob, seq in all_candidates[:self.beam_size * 2]:
                    length = seq.size(1)
                    penalty = (length ** self.length_penalty)
                    scored.append((log_prob / penalty, seq))
                scored.sort(key=lambda x: x[0], reverse=True)
                beams = [(score, seq) for score, seq in 
scored[:self.beam_size]]
            else:
                beams = all_candidates[:self.beam_size]
        
        # Return best
        best_seq = beams[0][1]
        return self.tokenizer.decode(best_seq[0], skip_special_tokens=True)
