    Flash Attention computation.
    
    Args:
        q: Query, shape: (batch, heads, seq_len, head_dim)
        k: Key, shape: (batch, heads, seq_len, head_dim)
        v: Value, shape: (batch, heads, seq_len, head_dim)
        mask: Optional mask, shape: (seq_len, seq_len) or broadcastable
        dropout_p: Dropout probability (training'de)
        softmax_scale: Scale factor (default: 1/√head_dim)
        causal: Causal masking (predict future tokens)
        
    Returns:
        output: (batch, heads, seq_len, head_dim)
        weights: (batch, heads, seq_len, seq_len) attention weights
    """
    batch_size, num_heads, seq_len, head_dim = q.shape
    
    # Default scale
    if softmax_scale is None:
        softmax_scale = 1.0 / math.sqrt(head_dim)
    
