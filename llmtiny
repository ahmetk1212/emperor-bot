"""
Streaming-compatible RMSNorm

Kullanım Senaryosu:
- Çok uzun sequence'ler (milyonlarca token)
- Chunk-based processing (overlap olmadan)
- Stateful inference (cache tutma)

Problem: Standart LayerNorm streaming'de sorunlu
- Tüm history'nin mean/variance'ını tutmalı
- Memory growth

Çözüm: Streaming normalization
- Running statistics (exponential moving average)
- Chunk-based processing
"""

import torch
import torch.nn as nn
from typing import Optional


class StreamingRMSNorm(nn.Module):
    """
    Streaming RMSNorm with running statistics.
    
    Eğitimde: Standard RMSNorm gibi çalışır
    Inference'da: Running statistics kullanır
    
    Args:
        hidden_size: Normalization dimension
        eps: Numerical stability
        momentum: EMA momentum for running stats
    """
    
    def __init__(
        self,
        hidden_size: int,
        eps: float = 1e-5,
        momentum: float = 0.1
    ):
        super().__init__()
        
        self.hidden_size = hidden_size
        self.eps = eps
        self.momentum = momentum
        
        # Learnable scale
        self.weight = nn.Parameter(torch.ones(hidden_size))
        
        # Running RMS buffer
        self.register_buffer(
            "running_rms",
            torch.ones(hidden_size),
            persistent=False
        )
        
        self.num_updates = 0
    
    def forward(
        self,
        x: torch.Tensor,
        update_stats: bool = True
    ) -> torch.Tensor:
        """
        Args:
            x: (batch, seq_len, hidden_size)
            update_stats: Running statistics güncellensin mi?
            
        Returns:
            Normalized tensor
        """
        # Compute current chunk's RMS
        chunk_rms = x.pow(2).mean(dim=-1, keepdim=True).add(self.eps).sqrt()
        
        # Update running statistics during training
        if update_stats and self.training:
            self._update_stats(chunk_rms.detach())
        
        # Use running stats for inference, chunk stats for training
        if self.training:
            normalizer = chunk_rms
        else:
            normalizer = self.running_rms.view(1, 1, -1)
        
        # Normalize and scale
        x_norm = (x / normalizer) * self.weight
        
        return x_norm
    
    def _update_stats(self, chunk_rms: torch.Tensor):
        """Exponential moving average güncelle."""
        # Mean over batch dimension
        chunk_rms_mean = chunk_rms.mean(dim=0).squeeze()  # (hidden_size,)
        
        # EMA update
        self.running_rms = (
            self.momentum * chunk_rms_mean +
            (1 - self.momentum) * self.running_rms
        )
        
        self.num_updates += 1
    
    def reset_stats(self):
        """Statistics'i resetle (batch split noktalarında kullanışlı)."""
        self.running_rms.fill_(1.0)
        self.num_updates = 0
    
    def extra_repr(self) -> str:
        return (
            f"hidden_size={self.hidden_size}, "
            f"momentum={self.momentum}, "
            f"updates={self.num_updates}"
        )


class AdaptiveRMSNorm(nn.Module):
    """
    Adaptive RMSNorm - Koşullu normalizasyon.
    
    Fikir: Farklı feature'lar farklı normalization'a ihtiyaç duyar.
    - Sparse features: Daha az normalization
    - Dense features: Daha fazla normalization
    
    Implementasyon: Gate mechanism ile.
    """
    
    def __init__(
        self,
        hidden_size: int,
        eps: float = 1e-5,
        num_groups: int = 4
    ):
        super().__init__()
        
        self.hidden_size = hidden_size
        self.num_groups = num_groups
        self.group_size = hidden_size // num_groups
        self.eps = eps
        
        # Learnable scale per group
        self.weight = nn.Parameter(torch.ones(hidden_size))
        
        # Adaptive gates per group
        self.gates = nn.Parameter(torch.zeros(num_groups))
        
    def forward(self, x: torch.Tensor) -> torch.Tensor:
        """
        Args:
            x: (batch, seq_len, hidden_size)
            
        Returns:
            Adaptively normalized tensor
        """
        batch, seq, hidden = x.shape
        
        # Reshape to groups
        x = x.view(batch, seq, self.num_groups, self.group_size)
        
        # Compute RMS per group
        rms = x.pow(2).mean(dim=-1, keepdim=True).add(self.eps).sqrt()
        
        # Normalize
        x_norm = x / rms
        
        # Apply gates (learnable intensity per group)
        gates = torch.sigmoid(self.gates).view(1, 1, self.num_groups, 1)
        x_norm = x_norm * (1 + gates)  # Additive gating
        
        # Reshape back and apply scale
        x_norm = x_norm.view(batch, seq, hidden) * self.weight
        
        return x_norm
