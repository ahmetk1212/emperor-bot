    Örnek: Token embeddings ve positional embeddings ayrı normalize.
    """
    
    def __init__(
        self,
        num_groups: int,
        group_size: int,
        eps: float = 1e-5
    ):
        super().__init__()
        
        assert num_groups * group_size > 0
        
        self.num_groups = num_groups
        self.group_size = group_size
        self.eps = eps
        
        self.weight = nn.Parameter(torch.ones(num_groups, group_size))
    
    def forward(self, x: torch.Tensor) -> torch.Tensor:
        """
        Args:
            x: (batch, ..., num_groups * group_size)
        """
        # Reshape to groups
        x = x.view(*x.shape[:-1], self.num_groups, self.group_size)
        
        # RMS per group
        rms = x.pow(2).mean(dim=-1, keepdim=True).add(self.eps).sqrt()
        
        # Normalize
        x = x / rms
        
        # Scale per group
        x = x * self.weight.unsqueeze(0)
        
        return x.flatten(-2)
