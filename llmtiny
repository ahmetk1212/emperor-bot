                    param.add_(param, alpha=-lr * wd)
                
                # LAMB: adaptive LR
                denom = (exp_avg_sq.sqrt() / 
math.sqrt(bias_correction2)).add_(eps)
                update = exp_avg / bias_correction1 / denom
                
                # LAMB: trust ratio clipping
                param_norm = param.norm().add_(eps)
                update_norm = update.norm()
                
                trust_ratio = param_norm / update_norm
                trust_ratio = torch.clamp(trust_ratio, 0, clip)
                
                param.add_(update, alpha=-lr * trust_ratio)
        
        return loss
