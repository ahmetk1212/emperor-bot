        self,
        raw_texts: List[str],
        tokenizer: Any,
        max_length: int = 2048,
        cache_dir: Optional[str] = None
    ):
        self.tokenizer = tokenizer
        self.max_length = max_length
        
        # Determine cache path
        if cache_dir:
            cache_path = Path(cache_dir) / "cached_dataset.pt"
        else:
            cache_path = None
        
        # Check cache
        if cache_path and cache_path.exists():
            print(f"Cache yükleniyor: {cache_path}")
            self.examples = torch.load(cache_path)
            print(f"Cache'den {len(self.examples):,} örnek 
yüklendi")
        else:
            print(f"Dataset tokenization başlıyor... 
({len(raw_texts)} metin)")
            
