        output = self.out_proj(attn_output) + x
        
        return output


class GroupedQueryAttention(nn.Module):
    """
    Grouped Query Attention (GQA).
    
    Standard MHA vs GQA vs MQA:
    
    Multi-Head Attention (MHA):
    - num_heads Q, K, V heads
    - En expressif
    - En pahalı (KV cache büyük)
    
    Multi-Query Attention (MQA):
    - num_heads Q, 1 K, V head
    - Hızlı, az bellek
    - Less expressive
    
    Grouped Query Attention (GQA):
    - num_heads Q, g K, V heads (g < num_heads)
    - Balance: Expressive + Fast
    
    Örnek:
    - num_heads = 12
    - num_kv_heads = 4
    - Her 3 Q head aynı K/V head'i paylaşır
    
    Referans: Ainslie et al. (GQA, 2023) - arXiv:2307.09288
    """
    
    def __init__(
        self,
        hidden_size: int,
        num_heads: int,
        num_kv_heads: int,
        head_dim: int = 64,
        dropout: float = 0.0,
        bias: bool = False
    ):
        super().__init__()
        
        assert num_heads % num_kv_heads == 0, \
            f"num_heads ({num_heads}) num_kv_heads ({num_kv_heads}) ile bölünebilir 
olmalı"
        
        self.hidden_size = hidden_size
        self.num_heads = num_heads
        self.num_kv_heads = num_kv_heads
        self.num_q_per_kv = num_heads // num_kv_heads
        self.head_dim = head_dim
        
        # Pre-norm
        self.norm = nn.RMSNorm(hidden_size)
        
        # Projections
        self.q_proj = nn.Linear(hidden_size, num_heads * head_dim, bias=bias)
        self.k_proj = nn.Linear(hidden_size, num_kv_heads * head_dim, bias=bias)
        self.v_proj = nn.Linear(hidden_size, num_kv_heads * head_dim, bias=bias)
        
        # Output
        self.out_proj = nn.Linear(num_heads * head_dim, hidden_size, bias=bias)
        
        # Dropout
        self.attn_dropout = nn.Dropout(dropout) if dropout > 0 else nn.Identity()
        
        # Scale
        self.scale = 1.0 / math.sqrt(head_dim)
    
    def forward(
        self,
        x: torch.Tensor,
        attention_mask: Optional[torch.Tensor] = None,
        is_causal: bool = True
    ) -> torch.Tensor:
        batch_size, seq_len, _ = x.shape
        
        # Pre-norm
        x_norm = self.norm(x)
        
        # Project
        q = self.q_proj(x_norm)
        k = self.k_proj(x_norm)
        v = self.v_proj(x_norm)
        
        # Reshape Q
        q = q.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 
2)
        
        # Reshape K, V
        k = k.view(batch_size, seq_len, self.num_kv_heads, 
self.head_dim).transpose(1, 2)
        v = v.view(batch_size, seq_len, self.num_kv_heads, 
self.head_dim).transpose(1, 2)
        
        # Repeat K, V for each Q group
        # (batch, num_kv, seq, dim) → (batch, num_heads, seq, dim)
        k = k.repeat_interleave(self.num_q_per_kv, dim=1)
        v = v.repeat_interleave(self.num_q_per_kv, dim=1)
        
        # Attention
        attn_output, _ = flash_attention(
            q, k, v,
            mask=attention_mask,
            dropout_p=self.dropout if self.training else 0.0,
            softmax_scale=self.scale,
            causal=is_causal
        )
        
        # Reshape and project
        attn_output = attn_output.transpose(1, 2).contiguous()
        attn_output = attn_output.view(batch_size, seq_len, -1)
        
        return self.out_proj(attn_output) + x


class MultiHeadLatentAttention(nn.Module):
    """
    Multi-Head Latent Attention (MLA).
    
    DeepSeek-V2'nin innovation'u.
    
    GQA/KVQ'nun daha da efficient versiyonu:
    - K ve V'yi düşük-rank latent space'e sıkıştır
    - Daha az KV cache
    - Daha expressif representation
    
    Not: Bu experimental implementasyon.
    Detaylar için DeepSeek-V2 paper'ına bakın.
    
    Referans: DeepSeek-AI (DeepSeek-V2, 2024)
    """
    
    def __init__(
        self,
        hidden_size: int,
        num_heads: int,
        head_dim: int = 64,
        kv_rank: int = 512,  # Latent dimension
        dropout: float = 0.0
    ):
        super().__init__()
        
        self.hidden_size = hidden_size
        self.num_heads = num_heads
        self.head_dim = head_dim
        self.kv_rank = kv_rank
        
        # Pre-norm
        self.norm = nn.RMSNorm(hidden_size)
        
        # Q projection
        self.q_proj = nn.Linear(hidden_size, num_heads * head_dim, bias=False)
        
        # Latent K, V compression
        self.kv_a_proj = nn.Linear(hidden_size, kv_rank, bias=False)
        self.kv_b_proj = nn.Linear(kv_rank, 2 * num_heads * head_dim, bias=False)
        
        # Output
        self.out_proj = nn.Linear(num_heads * head_dim, hidden_size, bias=False)
        
        self.scale = 1.0 / math.sqrt(head_dim)
        self.dropout = nn.Dropout(dropout)
    
    def forward(
        self,
        x: torch.Tensor,
        attention_mask: Optional[torch.Tensor] = None,
        is_causal: bool = True
    ) -> torch.Tensor:
        batch_size, seq_len, _ = x.shape
        
        x_norm = self.norm(x)
        
        # Q
        q = self.q_proj(x_norm)
        q = q.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 
2)
        
        # Latent K, V
        kv_latent = self.kv_a_proj(x_norm)  # (batch, seq, kv_rank)
        
        # Compress K, V
        kv_compressed = self.kv_b_proj(kv_latent)  # (batch, seq, 2*heads*head_dim)
        k, v = kv_compressed.chunk(2, dim=-1)
        
        k = k.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 
2)
        v = v.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 
2)
        
        # Attention
        attn_output, _ = flash_attention(
            q, k, v,
            mask=attention_mask,
            dropout_p=self.dropout.p if self.training else 0.0,
            softmax_scale=self.scale,
            causal=is_causal
        )
        
        # Output
        attn_output = attn_output.transpose(1, 2).contiguous()
        attn_output = attn_output.view(batch_size, seq_len, -1)
        
        return self.out_proj(attn_output) + x
