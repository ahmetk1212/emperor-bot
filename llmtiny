"""
Logging Utilities

Merkezi logging yapılandırması.
"""

import logging
import sys
from pathlib import Path
from typing import Optional
from datetime import datetime


def setup_logger(
    name: str = "nightshade",
    level: int = logging.INFO,
    log_file: Optional[str] = None,
    format_string: Optional[str] = None
) -> logging.Logger:
    """
    Logger ayarla.
    
    Args:
        name: Logger adı
        level: Logging seviyesi
        log_file: Log dosyası (opsiyonel)
        format_string: Log formatı
        
    Returns:
        Logger instance
    """
    if format_string is None:
        format_string = "[%(asctime)s] [%(levelname)s] [%(name)s] 
%(message)s"
    
    # Create logger
    logger = logging.getLogger(name)
    logger.setLevel(level)
    logger.handlers = []  # Clear existing handlers
    
    # Formatter
    formatter = logging.Formatter(format_string, datefmt="%Y-%m-%d %H:%M:%S")
    
    # Console handler
    console_handler = logging.StreamHandler(sys.stdout)
    console_handler.setLevel(level)
    console_handler.setFormatter(formatter)
    logger.addHandler(console_handler)
    
    # File handler
    if log_file:
        log_path = Path(log_file)
        log_path.parent.mkdir(parents=True, exist_ok=True)
        
        file_handler = logging.FileHandler(log_file)
        file_handler.setLevel(level)
        file_handler.setFormatter(formatter)
        logger.addHandler(file_handler)
    
    return logger


def get_logger(name: str = "nightshade") -> logging.Logger:
    """Logger al."""
    return logging.getLogger(name)


class TrainingLogger:
    """
    Training-specific logger.
    
    Eğitim metriklerini loglar.
    """
    
    def __init__(
        self,
        log_dir: str = "./logs",
        name: str = "training"
    ):
        self.log_dir = Path(log_dir)
        self.log_dir.mkdir(parents=True, exist_ok=True)
        
        self.name = name
        self.log_file = self.log_dir / 
f"{name}_{datetime.now():%Y%m%d_%H%M%S}.log"
        
        self.logger = setup_logger(name, log_file=str(self.log_file))
        
        self.metrics_history = {
            "train_loss": [],
            "val_loss": [],
            "learning_rate": [],
            "grad_norm": [],
            "steps": []
        }
    
    def log_metrics(self, step: int, **metrics):
        """Metrikleri logla."""
        msg_parts = [f"Step {step}"]
        
        for key, value in metrics.items():
            if isinstance(value, float):
                msg_parts.append(f"{key}={value:.4f}")
            else:
                msg_parts.append(f"{key}={value}")
            
            # History'ye ekle
            if key in self.metrics_history:
                self.metrics_history[key].append(value)
        
        # Steps history
        if "steps" not in self.metrics_history:
            self.metrics_history["steps"] = []
        self.metrics_history["steps"].append(step)
        
        self.logger.info(" | ".join(msg_parts))
    
    def log_info(self, message: str):
        """Info mesajı."""
        self.logger.info(message)
    
    def log_warning(self, message: str):
        """Warning mesajı."""
        self.logger.warning(message)
    
    def log_error(self, message: str):
        """Error mesajı."""
        self.logger.error(message)
