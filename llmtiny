        self.v_proj = nn.Linear(hidden_size, num_heads * head_dim, bias=False)
        
        # Output projection
        self.out_proj = nn.Linear(num_heads * head_dim, hidden_size, bias=False)
        
        # Scale
        self.scale = 1.0 / math.sqrt(head_dim)
        
        # Dropout
        self.dropout = nn.Dropout(dropout) if dropout > 0 else nn.Identity()
    
    def forward(
        self,
        x: torch.Tensor,
        attention_mask: Optional[torch.Tensor] = None
    ) -> torch.Tensor:
        """
        Args:
            x: (batch, seq_len, hidden_size)
            attention_mask: Optional attention mask
            
        Returns:
            output: (batch, seq_len, hidden_size)
        """
        batch_size, seq_len, _ = x.shape
        
        # Pre-norm
        x_norm = self.norm(x)
        
        # Gate (sigmoid ile [0,1])
        gate = torch.sigmoid(self.gate_proj(x_norm))  # (batch, seq, inner_dim)
        
        # Light K, V
        k = self.k_proj(x_norm)  # (batch, seq, num_heads*head_dim)
        v = self.v_proj(x_norm)
        
        # Q olarak x_norm kullan (basitleştirilmiş)
        q = x_norm
        
        # Reshape
        q = q.unsqueeze(1)  # (batch, 1, seq, hidden)
        k = k.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 
2)
        v = v.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 
2)
        
        # Truncate q to match inner dimension
        q_dim_per_head = self.inner_dim // self.num_heads
        if q_dim_per_head < self.head_dim:
            # Q daha küçük, K, V'yi projeksiyonla küçült
            q = self._project_q(x_norm, batch_size, seq_len)
        
        # Attention
        attn = torch.einsum('bqhd,bhhd->bhq', k, q) * self.scale
        
        if attention_mask is not None:
            attn = attn + attention_mask
            
        attn = F.softmax(attn, dim=-1)
        attn = self.dropout(attn)
        
        # Apply
        out = torch.einsum('bhq,bhvd->bqvd', attn, v).squeeze(2)
        
        # Project and apply gate
        out = self.out_proj(out)
        out = out * gate
        
        # Residual
        return out + x
    
    def _project_q(
        self,
        x: torch.Tensor,
        batch_size: int,
        seq_len: int
    ) -> torch.Tensor:
        """Q'yu uygun boyuta projekte et."""
        # Basit yaklaşım: x_norm tekrar kullan
        # Daha iyi: Ayrı Q projection ekle
        return x.unsqueeze(1)


class MultiScaleGatedAttention(nn.Module):
    """
    Multi-Scale Gated Attention.
    
    Farklı receptive field'larda paralel attention:
    1. Local (3-gram): Küçük kernel convolution
    2. Medium (7-gram): Orta kernel convolution
    3. Global: Full attention (light)
    
    Her ölçek bir gate ile ağırlıklandırılır.
    
    Bu yaklaşım Performer, CosFormer gibi
    linear attention variant'ları ile benzerlik taşır.
    """
    
    def __init__(
        self,
        hidden_size: int,
        num_heads: int = 8,
        kernel_sizes: list = [3, 7],
        dropout: float = 0.0
    ):
        super().__init__()
        
        self.hidden_size = hidden_size
        self.num_heads = num_heads
        self.head_dim = hidden_size // num_heads
        self.kernel_sizes = kernel_sizes
        
        # Pre-norm
        self.norm = nn.RMSNorm(hidden_size)
        
        # Q projection
        self.q_proj = nn.Linear(hidden_size, hidden_size, bias=False)
        
        # Multi-scale K, V projections
        self.k_proj = nn.Linear(hidden_size, hidden_size, bias=False)
        
        # Depthwise convolutions for multi-scale V
        self.v_convs = nn.ModuleList([
            nn.Conv1d(
                hidden_size, hidden_size,
                kernel_size=k,
                padding=k // 2,
                groups=num_heads  # Depthwise per head
            )
            for k in kernel_sizes
        ])
        
        # Learnable gates for each scale + global
        self.scale_gates = nn.Parameter(torch.ones(len(kernel_sizes) + 1))
        
        # Output
        self.out_proj = nn.Linear(hidden_size, hidden_size, bias=False)
        
        # Scale
        self.scale = 1.0 / math.sqrt(self.head_dim)
        
        # Dropout
        self.dropout = nn.Dropout(dropout) if dropout > 0 else nn.Identity()
    
    def forward(
        self,
        x: torch.Tensor,
        attention_mask: Optional[torch.Tensor] = None
    ) -> torch.Tensor:
        batch_size, seq_len, _ = x.shape
        
        x_norm = self.norm(x)
        
        # Q, K
        q = self.q_proj(x_norm)
        k = self.k_proj(x_norm)
        
        # Reshape for multi-head
        q = q.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 
2)
        k = k.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 
2)
        
        # Multi-scale V
        v = x_norm.transpose(1, 2)  # (batch, hidden, seq)
        
        v_scales = []
        for conv in self.v_convs:
            v_conv = conv(v).transpose(1, 2)  # Back to (batch, seq, hidden)
            v_conv = v_conv.view(batch_size, seq_len, self.num_heads, 
self.head_dim).transpose(1, 2)
            v_scales.append(v_conv)
        
        # Global V (no conv)
        v_global = x_norm.view(batch_size, seq_len, self.num_heads, 
self.head_dim).transpose(1, 2)
        v_scales.append(v_global)
        
        # Softmax gates
        weights = F.softmax(self.scale_gates, dim=0)
        
        # Compute each scale
        outputs = []
        for i, v_s in enumerate(v_scales):
            # Attention
            attn = torch.einsum('bhqd,bhhd->bhq', q, k) * self.scale
            
            if attention_mask is not None:
                attn = attn + attention_mask
                
            attn = F.softmax(attn, dim=-1)
            attn = self.dropout(attn)
            
            # Apply to V
            out = torch.einsum('bhq,bhvd->bhqd', attn, v_s)
            outputs.append(out * weights[i])
        
        # Combine scales
        out = sum(outputs)
        
        # Reshape and project
        out = out.transpose(1, 2).contiguous()
        out = out.view(batch_size, seq_len, -1)
        
        return self.out_proj(out) + x


class GatedResidualAttention(nn.Module):
    """
    Gated Residual Attention (GRA).
    
    Basit ama etkili:
    - Attention output'u residual ile gate'le
    - Ne kadar "attention" gerekli kontrolü
    
    Formül:
        output = x + gate * attention(x)
        
    gate = sigmoid(Linear(x))
    
    Bu basit mekanizma training stability'yi artırır.
    """
    
    def __init__(
        self,
        hidden_size: int,
        num_heads: int = 8,
        head_dim: int = 64,
        dropout: float = 0.0
    ):
        super().__init__()
        
        self.hidden_size = hidden_size
        self.num_heads = num_heads
        self.head_dim = head_dim
        
        # Pre-norm
        self.norm = nn.RMSNorm(hidden_size)
        
        # Attention
        self.q_proj = nn.Linear(hidden_size, hidden_size, bias=False)
        self.k_proj = nn.Linear(hidden_size, hidden_size, bias=False)
        self.v_proj = nn.Linear(hidden_size, hidden_size, bias=False)
        self.out_proj = nn.Linear(hidden_size, hidden_size, bias=False)
        
        # Gate
        self.gate = nn.Sequential(
            nn.Linear(hidden_size, hidden_size, bias=False),
            nn.Sigmoid()
        )
        
        self.scale = 1.0 / math.sqrt(head_dim)
        self.dropout = nn.Dropout(dropout)
    
    def forward(
        self,
        x: torch.Tensor,
        attention_mask: Optional[torch.Tensor] = None
    ) -> torch.Tensor:
        batch_size, seq_len, _ = x.shape
        
        x_norm = self.norm(x)
        
        # Q, K, V
        q = self.q_proj(x_norm).view(batch_size, seq_len, self.num_heads, 
self.head_dim).transpose(1, 2)
        k = self.k_proj(x_norm).view(batch_size, seq_len, self.num_heads, 
self.head_dim).transpose(1, 2)
        v = self.v_proj(x_norm).view(batch_size, seq_len, self.num_heads, 
self.head_dim).transpose(1, 2)
        
        # Attention
        attn = torch.einsum('bhqd,bhhd->bhq', q, k) * self.scale
        
        if attention_mask is not None:
            attn = attn + attention_mask
            
        attn = F.softmax(attn, dim=-1)
        attn = self.dropout(attn)
        
        # Apply
        out = torch.einsum('bhq,bhvd->bhqd', attn, v)
        out = out.transpose(1, 2).contiguous().view(batch_size, seq_len, -1)
        out = self.out_proj(out)
        
        # Gating
        gate_value = self.gate(x_norm)
        out = x + out * gate_value
        
        return out
