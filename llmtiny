    batch_size, seq_len = 2, 16
    vocab_size = model.config.vocab_size
    
    input_ids = torch.randint(0, vocab_size, (batch_size, seq_len))
    labels = input_ids.clone()
    
    # Forward
    output = model(input_ids, labels=labels)
    loss = output["loss"]
    
    # Backward
    loss.backward()
    optimizer.step()
    optimizer.zero_grad()
    
