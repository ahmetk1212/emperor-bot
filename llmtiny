        torch.manual_seed(seed)
        torch.cuda.manual_seed_all(seed)
    
    def train(self):
        """Ana eğitim döngüsü."""
        print("\n" + "="*60)
        print("EĞİTİM BAŞLIYOR")
        print("="*60)
        print(f"Model parametreleri: {sum(p.numel() for p in 
self.model.parameters()):,}")
        print(f"Toplam adım: {self._get_num_steps()}")
        print(f"Batch size: {self.config.training.batch_size}")
        print(f"Gradient accumulation: 
{self.gradient_accumulation_steps}")
        print(f"Effective batch size: 
{self.config.training.effective_batch_size}")
        print("="*60 + "\n")
        
        # Callbacks
        self.callback_handler.on_train_begin()
        
        # Training loop
        self.model.train()
        
        epoch_iterator = range(self.config.training.max_epochs or 100)
        progress_bar = tqdm(total=self._get_num_steps(), 
desc="Training")
        
        while self.global_step < self._get_num_steps():
            for epoch in epoch_iterator:
                self.epoch = epoch
                self.callback_handler.on_epoch_begin(epoch)
                
                for batch in self.train_dataloader:
                    # Training step
                    loss, metrics = self.training_step(batch)
                    
                    # Update progress
                    progress_bar.update(1)
                    progress_bar.set_postfix({
                        "loss": f"{loss:.4f}",
                        "lr": f"{self.scheduler.get_lr() if 
hasattr(self.scheduler, 'get_lr') else 
self.optimizer.param_groups[0]['lr']:.2e}"
                    })
                    
                    # Callbacks
                    self.callback_handler.on_step_end(self.global_step, 
metrics)
                    
                    # Check max steps
                    if self.global_step >= self._get_num_steps():
                        break
                
                self.callback_handler.on_epoch_end(epoch)
            
            # Check max steps again
            if self.global_step >= self._get_num_steps():
                break
        
        progress_bar.close()
        
        # Save final checkpoint
        self.checkpoint_manager.save_last_checkpoint(
            step=self.global_step,
            metrics={"final_loss": loss}
        )
        
        self.callback_handler.on_train_end()
        
        print("\n" + "="*60)
        print("EĞİTİM TAMAMLANDI!")
        print("="*60)
    
    def training_step(self, batch: Dict[str, torch.Tensor]) -> tuple:
        """
        Single training step.
        
        Args:
            batch: Training batch
            
        Returns:
            (loss, metrics) tuple
        """
        # Move batch to device
        batch = {k: v.to(self.device) if isinstance(v, torch.Tensor) 
else v 
                 for k, v in batch.items()}
        
        # Forward pass with mixed precision
        with autocast(enabled=self.scaler is not None):
            outputs = self.model(
                input_ids=batch["input_ids"],
                attention_mask=batch.get("attention_mask"),
                labels=batch.get("labels")
            )
            
            loss = outputs["loss"]
            
            # Scale loss for gradient accumulation
            if self.gradient_accumulation_steps > 1:
                loss = loss / self.gradient_accumulation_steps
        
        # Backward pass
        if self.scaler:
            self.scaler.scale(loss).backward()
        else:
            loss.backward()
        
        # Gradient clipping
        if self.global_step % self.gradient_accumulation_steps == 0:
            if self.scaler:
                self.scaler.unscale_(self.optimizer)
            
            torch.nn.utils.clip_grad_norm_(
                self.model.parameters(),
                self.config.training.max_grad_norm
            )
            
            # Optimizer step
            if self.scaler:
                self.scaler.step(self.optimizer)
                self.scaler.update()
            else:
                self.optimizer.step()
            
            self.optimizer.zero_grad()
            
            # Scheduler step
            if hasattr(self.scheduler, 'step'):
                self.scheduler.step()
        
        # Metrics
        metrics = {
            "loss": loss.item() * self.gradient_accumulation_steps,
            "lr": self.optimizer.param_groups[0]["lr"]
        }
        
        self.global_step += 1
        
        return loss.item() * self.gradient_accumulation_steps, metrics
    
    def evaluate(self) -> Dict[str, float]:
        """
        Validation evaluation.
        
        Returns:
            Metrics dict
        """
        if not self.val_dataloader:
            return {}
        
        self.model.eval()
        
        total_loss = 0.0
        num_batches = 0
        
        with torch.no_grad():
            for batch in self.val_dataloader:
                batch = {k: v.to(self.device) if isinstance(v, 
torch.Tensor) else v 
                         for k, v in batch.items()}
                
                with autocast(enabled=self.scaler is not None):
                    outputs = self.model(
                        input_ids=batch["input_ids"],
                        attention_mask=batch.get("attention_mask"),
                        labels=batch.get("labels")
                    )
                
                total_loss += outputs["loss"].item()
                num_batches += 1
        
        self.model.train()
        
        avg_loss = total_loss / max(1, num_batches)
        
        return {
            "val_loss": avg_loss,
            "val_perplexity": math.exp(avg_loss)
        }
    
    def predict(self, batch: Dict[str, torch.Tensor]) -> Dict[str, 
torch.Tensor]:
        """Inference yap."""
        self.model.eval()
        
        batch = {k: v.to(self.device) if isinstance(v, torch.Tensor) 
else v 
                 for k, v in batch.items()}
        
        with torch.no_grad():
            with autocast(enabled=self.scaler is not None):
                outputs = self.model(
                    input_ids=batch["input_ids"],
                    attention_mask=batch.get("attention_mask")
                )
        
        self.model.train()
        
        return outputs


class LMTrainer(Trainer):
    """
    Language Model Trainer.
    
    NightShade LLM için özelleştirilmiş trainer.
    Ek özellikler:
    - Perplexity hesaplama
    - Text generation evaluation
    - Custom metrics
    """
    
    def __init__(
        self,
        model: nn.Module,
        config: NightShadeConfig,
        train_dataloader: DataLoader,
        val_dataloader: Optional[DataLoader] = None,
        tokenizer: Optional[Any] = None,
        callbacks: Optional[List[Callback]] = None
    ):
        super().__init__(model, config, train_dataloader, 
val_dataloader, callbacks)
        
        self.tokenizer = tokenizer
    
    def compute_perplexity(self, batch: Dict[str, torch.Tensor]) -> 
float:
        """Perplexity hesapla."""
        batch = {k: v.to(self.device) if isinstance(v, torch.Tensor) 
else v 
                 for k, v in batch.items()}
        
        with torch.no_grad():
            outputs = self.model(
                input_ids=batch["input_ids"],
                labels=batch["labels"]
            )
        
        loss = outputs["loss"].item()
        perplexity = math.exp(loss)
        
        return perplexity
    
    def generate_sample(
        self,
        prompt: str,
        max_new_tokens: int = 50
    ) -> str:
        """Örnek generation yap."""
        if not self.tokenizer:
            return "Tokenizer not available"
        
        self.model.eval()
        
        # Encode
        input_ids = self.tokenizer.encode(prompt, return_tensors="pt")
        input_ids = input_ids.to(self.device)
        
        # Generate
        with torch.no_grad():
            generated_ids = self.model.generate(
                input_ids,
                max_new_tokens=max_new_tokens,
                do_sample=True,
                temperature=0.8
            )
        
        # Decode
        generated_text = self.tokenizer.decode(generated_ids[0], 
skip_special_tokens=True)
        
        self.model.train()
        
        return generated_text


