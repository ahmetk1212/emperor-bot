@dataclass
class NightShadeConfig:
    """
    Ana konfigürasyon sınıfı.
    Tüm alt konfigürasyonları bir araya getirir.
    """
    model: ModelConfig = field(default_factory=ModelConfig)
    data: DataConfig = field(default_factory=DataConfig)
    training: TrainingConfig = field(default_factory=TrainingConfig)
    distributed: DistributedConfig = field(default_factory=DistributedConfig)
    inference: InferenceConfig = field(default_factory=InferenceConfig)
    
    # === Project Info ===
    project_name: str = "nightshade-llm"
    experiment_name: str = "baseline"
    output_dir: str = "./outputs"
    save_total_limit: int = 5
    
    # === Device ===
    device: str = "auto"  # auto, cpu, cuda
    
    @classmethod
    def from_yaml(cls, path: Union[str, Path]) -> "NightShadeConfig":
        """YAML dosyasından yükle."""
        path = Path(path)
        if not path.exists():
            raise FileNotFoundError(f"Config dosyası bulunamadı: {path}")
            
        with open(path, "r") as f:
            data = yaml.safe_load(f)
            
        return cls.from_dict(data)
    
    @classmethod
    def from_dict(cls, data: dict) -> "NightShadeConfig":
        """Dict'ten oluştur."""
        config = cls()
        
        # Flat dict'i nested config'lere map et
        mapping = {
            "model": data.get("model", {}),
            "data": data.get("data", {}),
            "training": data.get("training", {}),
            "distributed": data.get("distributed", {}),
            "inference": data.get("inference", {}),
        }
        
        # Top-level fields
        for key in ["project_name", "experiment_name", "output_dir", "device", "save_total_limit"]:
            if key in data:
                setattr(config, key, data[key])
        
        # Sub-configs
        for sub_key, sub_data in mapping.items():
            if sub_key in data and sub_data:
                sub_config = getattr(config, sub_key)
                for k, v in sub_data.items():
                    if hasattr(sub_config, k):
                        setattr(sub_config, k, v)
                        
        return config
    
    def to_yaml(self, path: Union[str, Path]):
        """YAML dosyasına kaydet."""
        path = Path(path)
        path.parent.mkdir(parents=True, exist_ok=True)
        
        data = {
            "project_name": self.project_name,
            "experiment_name": self.experiment_name,
            "output_dir": self.output_dir,
            "device": self.device,
            "save_total_limit": self.save_total_limit,
            "model": asdict(self.model),
            "data": asdict(self.data),
            "training": asdict(self.training),
            "distributed": asdict(self.distributed),
            "inference": asdict(self.inference),
        }
        
        with open(path, "w") as f:
            yaml.dump(data, f, default_flow_style=False, sort_keys=False)
    
    def to_dict(self) -> dict:
        """Dict'e dönüştür."""
        return {
            "project_name": self.project_name,
            "experiment_name": self.experiment_name,
            "output_dir": self.output_dir,
            "model": asdict(self.model),
            "data": asdict(self.data),
            "training": asdict(self.training),
            "distributed": asdict(self.distributed),
            "inference": asdict(self.inference),
        }
    
    def save(self, save_dir: Union[str, Path]):
        """Tüm konfigürasyonu kaydet."""
        save_dir = Path(save_dir)
        save_dir.mkdir(parents=True, exist_ok=True)
        
        self.to_yaml(save_dir / "config.yaml")
        
        # Model card
        model_card = f"""---
language: tr
license: apache-2.0
tags:
- llm
- text-generation
- pytorch
- nightshade
---

# NightShade LLM

## Architecture
- Type: Hybrid SSM-Attention
- Parameters: ~{self.model.hidden_size * self.model.num_layers * 4:,}
- Hidden Size: {self.model.hidden_size}
- Layers: {self.model.num_layers}
- Heads: {self.model.num_heads}
- Max Seq Length: {self.model.max_seq_length}

## Training
- Batch Size: {self.training.batch_size}
- Learning Rate: {self.training.learning_rate}
- Max Steps: {self.training.max_steps}

## Vocab
- Vocabulary Size: {self.model.vocab_size}
- Tokenizer Type: {self.data.tokenizer_type}
"""
        (save_dir / "README.md").write_text(model_card)
        
    def copy(self) -> "NightShadeConfig":
        """Deep copy oluştur."""
        return copy.deepcopy(self)


