    def _get_num_steps(self) -> int:
        """Toplam training step sayısını hesapla."""
        if self.config.training.max_steps:
            return self.config.training.max_steps
        
        if self.config.training.max_epochs:
            num_batches = len(self.train_dataloader)
            return num_batches * self.config.training.max_epochs
        
        # Default
        return len(self.train_dataloader) * 100
    
    def _set_seed(self, seed: int):
