    parser.add_argument("--max_tokens", type=int, default=100, help="Max new 
tokens")
    parser.add_argument("--temperature", type=float, default=0.8, 
help="Temperature")
    parser.add_argument("--top_p", type=float, default=0.95, help="Top-p")
    parser.add_argument("--top_k", type=int, default=50, help="Top-k")
    parser.add_argument("--do_sample", action="store_true", help="Use 
sampling")
    parser.add_argument("--num_return", type=int, default=1, help="Number of 
outputs")
    
    args = parser.parse_args()
    
    print("="*60)
    print("NightShade LLM Generator")
    print("="*60)
    
    # Load tokenizer
    tokenizer_path = args.tokenizer or str(Path(args.model).parent / 
"tokenizer.json")
    
    if Path(tokenizer_path).exists():
        tokenizer = BPETokenizer.load(tokenizer_path)
        print(f"Tokenizer yüklendi: {tokenizer_path}")
    else:
        print("Tokenizer bulunamadı, örnek tokenizer kullanılıyor...")
        tokenizer = BPETokenizer(vocab_size=30000)
        tokenizer.train(["tests/sample_data.txt"])
    
    # Load model
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    print(f"Device: {device}")
    
    # Load checkpoint
    checkpoint = torch.load(args.model, map_location=device)
    
    # Get config
    if args.config:
        model_config = NightShadeConfig.from_yaml(args.config).model
    elif "config" in checkpoint:
        model_config = checkpoint["config"]
    else:
        print("Config bulunamadı, default kullanılıyor...")
        model_config = ModelConfig()
    
    # Create model
    model = NightShadeLM(model_config)
    
    # Load weights
    if "model_state_dict" in checkpoint:
        model.load_state_dict(checkpoint["model_state_dict"])
    else:
        model.load_state_dict(checkpoint)
    
    model = model.to(device)
    model.eval()
    
    print(f"Model yüklendi!")
    print(f"Parametreler: {model.get_num_params():,}")
    print("="*60)
    
    # Create generator
    generator = TextGenerator(model, tokenizer, device)
    generator.set_sampling_strategy(
        strategy="nucleus" if args.do_sample else "greedy",
        temperature=args.temperature,
        top_k=args.top_k,
        top_p=args.top_p
    )
    
    # Generate
    print(f"\nPrompt: {args.prompt}")
    print("-"*60)
    
    results = generator.generate(
        prompts=args.prompt,
        max_new_tokens=args.max_tokens,
        do_sample=args.do_sample,
        num_return_sequences=args.num_return
    )
    
    for i, result in enumerate(results):
        print(f"\n[Output {i+1}]")
        print(result)
    
    print("-"*60)


if __name__ == "__main__":
    main()
