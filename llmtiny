            "config": self._get_model_config(),
        }
        
        # Add optimizer state
        if self.optimizer:
            checkpoint["optimizer_state_dict"] = self.optimizer.state_dict()
        
        # Add scheduler state
        if self.scheduler:
            checkpoint["scheduler_state_dict"] = self.scheduler.state_dict()
        
        # Add metrics
        if metrics:
            checkpoint["metrics"] = metrics
        
        # Add tags
        if tags:
            checkpoint["tags"] = tags
        
        # Determine checkpoint name
        if save_best:
            checkpoint_name = "best_model.pt"
        else:
            checkpoint_name = f"checkpoint_step_{step}.pt"
        
        checkpoint_path = self.save_dir / checkpoint_name
        
        # Save
        torch.save(checkpoint, checkpoint_path)
        
        print(f"Checkpoint kaydedildi: {checkpoint_path}")
        
        # Update best metric
        if metrics and self.config.metric_for_best in metrics:
            current_metric = metrics[self.config.metric_for_best]
            
            is_better = (
                self.best_metric is None or
                (self.config.greater_is_better and current_metric > 
