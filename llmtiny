        k_fa = k.transpose(1, 2)
        v_fa = v.transpose(1, 2)
        
        output = flash_attn_func(
            q_fa, k_fa, v_fa,
            dropout_p=dropout_p,
            softmax_scale=softmax_scale,
            causal=causal
