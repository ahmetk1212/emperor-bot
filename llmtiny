    Token Embedding Layer.
    
    Args:
        vocab_size: Kelime dağarcığı boyutu
        hidden_size: Embedding boyutu
        padding_idx: Padding token'ın index'i (opsiyonel)
        init_std: Initialization standard deviation
        
    Not: Padding token normalde "sıfır" vektör olur.
    Bunu engellemek için dikkatli init şart.
    """
    
    def __init__(
        self,
        vocab_size: int,
        hidden_size: int,
        padding_idx: Optional[int] = None,
        init_std: float = 0.02
    ):
