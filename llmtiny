"""
Bellek Yönetimi ve Profileme

GPU/CPU bellek kullanımını izleme ve optimize etme.
"""

import torch
import gc
from typing import Dict, Optional
from contextlib import contextmanager
import psutil


def get_memory_usage(device: Optional[torch.device] = None) -> Dict[str, 
float]:
    """
    Bellek kullanımını al.
    
    Args:
        device: GPU device (None = current device)
        
    Returns:
        Bellek kullanım bilgileri (GB cinsinden)
    """
    info = {}
    
    # CPU memory
    process = psutil.Process()
    cpu_memory = process.memory_info().rss / 1024**3
    info["cpu_rss_gb"] = round(cpu_memory, 2)
    
    # GPU memory
    if torch.cuda.is_available():
        gpu_device = device or torch.cuda.current_device()
        
        allocated = torch.cuda.memory_allocated(gpu_device) / 1024**3
        reserved = torch.cuda.memory_reserved(gpu_device) / 1024**3
        max_allocated = torch.cuda.max_memory_allocated(gpu_device) / 1024**3
        
        total = torch.cuda.get_device_properties(gpu_device).total_memory / 
1024**3
        free = total - allocated
        
        info["gpu_allocated_gb"] = round(allocated, 2)
        info["gpu_reserved_gb"] = round(reserved, 2)
        info["gpu_max_allocated_gb"] = round(max_allocated, 2)
        info["gpu_total_gb"] = round(total, 2)
        info["gpu_free_gb"] = round(free, 2)
    
    return info


def clear_memory():
    """Belleği temizle."""
    gc.collect()
    
    if torch.cuda.is_available():
        torch.cuda.empty_cache()
        torch.cuda.synchronize()


class MemoryTracker:
    """
    Bellek kullanımını takip eder.
    
    Context manager olarak kullanılabilir.
    """
    
    def __init__(self, name: str = "Operation"):
        self.name = name
        self.start_memory = None
        self.peak_memory = None
    
    def __enter__(self):
        clear_memory()
        
        if torch.cuda.is_available():
            torch.cuda.reset_peak_memory_stats()
        
        self.start_memory = get_memory_usage()
        
        return self
    
    def __exit__(self, exc_type, exc_val, exc_tb):
        self.end_memory = get_memory_usage()
        self.compute_stats()
        
        print(f"\n{'='*50}")
        print(f"Memory Usage: {self.name}")
        print(f"{'='*50}")
        print(f"CPU: {self.start_memory.get('cpu_rss_gb', 0):.2f} GB → 
{self.end_memory.get('cpu_rss_gb', 0):.2f} GB")
        
        if torch.cuda.is_available():
            print(f"GPU Allocated: {self.start_memory.get('gpu_allocated_gb', 
0):.2f} GB → {self.end_memory.get('gpu_allocated_gb', 0):.2f} GB")
            print(f"GPU Peak: {self.end_memory.get('gpu_max_allocated_gb', 
0):.2f} GB")
        
        print(f"{'='*50}\n")
    
