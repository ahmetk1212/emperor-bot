### 📁 Dosya: `nightshade/model/norms/rmsnorm.py`

```python
"""
Root Mean Square Layer Normalization (RMSNorm)

RMSNorm vs LayerNorm Karşılaştırması:

LayerNorm:
    y = (x - mean) / sqrt(var + eps) * gamma + beta
    - Mean ve variance hesapla
    - 2 geçiş gerektirir

RMSNorm:
    y = x / RMS(x) * gamma
    where RMS(x) = sqrt(mean(x²) + eps)
    - Sadece RMS hesapla
    - ~10-20% daha hızlı
    - Hafif performans farkı (kabul edilebilir)

Referans: Zhang & Sennrich (RMSNorm, 2019)
"""

import torch
import torch.nn as nn
from typing import Optional


class RMSNorm(nn.Module):
    """
    Root Mean Square Normalization.
    
    LayerNorm'dan farkı:
    - Mean çıkarmaz (merkezi dağılım korunur)
    - Sadece RMS üzerinden normalizasyon
    - Daha az hesaplama
    
    Args:
        hidden_size: Normalize edilecek dimension
        eps: Numerical stability epsilon
        elementwise_affine: Learnable scale kullanılssın mı?
        
    Not: Bias (beta) kaldırılmış çünkü RMSNorm'ta mean çıkarılmıyor.
    """
    
    def __init__(
        self,
        hidden_size: int,
        eps: float = 1e-5,
        elementwise_affine: bool = True
    ):
        super().__init__()
        
        self.hidden_size = hidden_size
        self.eps = eps
        self.elementwise_affine = elementwise_affine
        
        if elementwise_affine:
            # Gamma (scale) parameter
            self.weight = nn.Parameter(torch.ones(hidden_size))
        else:
            self.register_parameter("weight", None)
    
    def forward(self, x: torch.Tensor) -> torch.Tensor:
        """
        Args:
            x: Herhangi bir shape (son dimension normalize edilir)
            
        Returns:
            Normalized tensor, aynı shape
        """
        # Compute RMS: sqrt(mean(x²) + eps)
        # x.pow(2) = x²
        # mean(-1) = son dimension üzerinden ortalama
        rms = x.pow(2).mean(dim=-1, keepdim=True).add(self.eps).sqrt()
        
        # Normalize
        x = x / rms
        
        # Apply learnable scale
        if self.weight is not None:
            x = x * self.weight
            
        return x
    
    def extra_repr(self) -> str:
        return (
            f"hidden_size={self.hidden_size}, "
            f"eps={self.eps}, "
            f"elementwise_affine={self.elementwise_affine}"
